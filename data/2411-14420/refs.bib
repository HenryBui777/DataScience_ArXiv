@techreport{Sto82,
  author = {Harold S. Stone},
  abstract = {This paper describes an algorithm for first-fit memory allocation that uses the FETCH-AND-ADD instruction to achieve a high degree of parallelism in a multiprocessor system.  In the scheme described, multiple requests for memory can be granted in a fully parallel fashion.  However, the algorithm does require locking to force serialization for some instances of memory deallocation.  The paper presents a procedure for analyzing potential conflicts among subroutines to determine where locks must be inserted into code for protection.  The parallelism achieved through the use of FETCH-AND-ADD makes use of associative updates on both pointers and counters.  The use of pointers in this contexts is somewhat unusual.},
  institution = {IBM Research},
  comments = {Eric got a copy from Stanford University.},
  title = {Parallel Memory Allocation using the {FETCH-AND-ADD},
  number = {RC 9674},
}
