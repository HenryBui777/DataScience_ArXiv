@article{Camp:2000ht,
  author = {J. B. Camp and H. Yamamoto and S. E. Whitcomb and D. E. McClelland},
  journal = {J. Opt. Soc. Am. A},
  keywords = {Fabry-Perot; Interferometry; Fabry Perot interferometers; Laser beams; Laser interferometry; Laser sources; Michelson interferometers; Phase shift},
  number = {1},
  pages = {120--128},
  publisher = {OSA},
  title = {Analysis of light noise sources in a recycled {M},
  volume = {17},
  month = {Jan},
  year = {2000},
  url = {http://josaa.osa.org/abstract.cfm?URI=josaa-17-1-120},
  doi = {10.1364/JOSAA.17.000120},
  abstract = {We present a method by which the effect of laser field variations on the signal output of an interferometric gravitational wave detector is rigorously determined. Using the Laser Interferometer Gravitational Wave Observatory (LIGO) optical configuration of a power recycled Michelson interferometer with Fabry--Perot arm cavities as an example, we calculate the excess noise after the input filter cavity (mode cleaner) and the dependence of the detector strain sensitivity on laser frequency and amplitude noise, radio frequency oscillator noise, and scattered-light phase noise. We find that noise on the radio frequency sidebands generally limits the detector's sensitivity.},
}

