@article{Kwee2012,
  author = {P. Kwee and C. Bogan and K. Danzmann and M. Frede and H. Kim and P. King and J. P\"{o},
  journal = {Opt. Express},
  keywords = {Interferometry; Laser stabilization ; High power lasers; Laser beams; Laser systems; Optical components; Optical design; Optical standards},
  number = {10},
  pages = {10617--10634},
  publisher = {OSA},
  title = {Stabilized high-power laser system for the gravitational wave detector {A},
  volume = {20},
  month = {May},
  year = {2012},
  url = {http://www.opticsexpress.org/abstract.cfm?URI=oe-20-10-10617},
  doi = {10.1364/OE.20.010617},
  abstract = {An ultra-stable, high-power cw Nd:YAG laser system, developed for the ground-based gravitational wave detector Advanced LIGO (Laser Interferometer Gravitational-Wave Observatory), was comprehensively characterized. Laser power, frequency, beam pointing and beam quality were simultaneously stabilized using different active and passive schemes. The output beam, the performance of the stabilization, and the cross-coupling between different stabilization feedback control loops were characterized and found to fulfill most design requirements. The employed stabilization schemes and the achieved performance are of relevance to many high-precision optical experiments.},
}

@article{PSL2,
  author = {Fabian Thies and Nina Bode and Patrick Oppermann and Maik Frede and Bastian Schulz and Benno Willke},
  journal = {Opt. Lett.},
  keywords = {Diode lasers; High power lasers; Laser amplifiers; Laser beams; Laser crystals; Laser systems},
  number = {3},
  pages = {719--722},
  publisher = {Optica Publishing Group},
  title = {{Nd:YVO4 high-power master oscillator power amplifier laser system for second-generation gravitational wave detectors},
  volume = {44},
  month = {Feb},
  year = {2019},
  url = {https://opg.optica.org/ol/abstract.cfm?URI=ol-44-3-719},
  doi = {10.1364/OL.44.000719},
  abstract = {Ultrastable high-power laser systems are essential components of the long baseline interferometers that detected the first gravitational waves from merging black holes and neutron stars. One way to further increase the sensitivity of current generation gravitational wave detectors (GWDs) is to increase the laser power injected into the interferometers. In this Letter, we describe and characterize a 72 W and a 114 W linearly polarized, single-frequency laser system at a wavelength of 1064 nm, each based on single-pass Nd:YVO4 power amplifiers. Both systems have low power and frequency noise and very high spatial purity with less than 10.7\% and 2.9\% higher order mode content, respectively. We demonstrate the simple integration of these amplifiers into the laser stabilization environment of operating GWDs and show stable low-noise operation of one of the amplifier systems in such an environment for more than 45 days.},
}

