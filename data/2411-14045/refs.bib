@article{CrTe2(2022),
  author = {Xian, Jing-Jing
and Wang, Cong
and Nie, Jin-Hua
and Li, Rui
and Han, Mengjiao
and Lin, Junhao
and Zhang, Wen-Hao
and Liu, Zhen-Yu
