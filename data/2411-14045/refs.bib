  journal = {Journal of Alloys and Compounds},
  volume = {890},
  pages = {161818},
  year = {2022},
  issn = {0925-8388},
  doi = {https://doi.org/10.1016/j.jallcom.2021.161818},
  url = {https://www.sciencedirect.com/science/article/pii/S0925838821032278},
  author = {Shasha Sun and Jian Liang and Ruobai Liu and Wei Shen and Haijing Wu and Mingming Tian and Lulu Cao and Yutian Yang and Zhaocong Huang and Weiwei Lin and Jun Du and Zhenhua Ni and Yongbing Xu and Qian Chen and Ya Zhai},
  keywords = {Chromium tellurides, Chemical vapor deposition, Room temperature ferromagnet, Anisotropic magnetoresistance, Perpendicular magnetic anisotropy},
  abstract = {Chromium tellurides have triggered tremendous investigations in physics and materials science, where their unique properties offer excellent opportunities for spintronic applications. Here, we report anisotropic magnetoresistance (AMR) of ferromagnetic CrTe single crystal flake grown by chemical vapor deposition. An individual hexagonal flake exhibits an easy magnetization axis along its normal direction, and cooling from room temperature to low temperature, its electrical resistance measured with the magnetization parallel to current geometry is larger than that for the perpendicular to the current geometry, indicating the presence of an AMR behavior. The AMR ratio has been found to increase with decreasing temperature and is 5.2% at 5 K, comparable with general magnetic transition metal and alloy. This suggests CrTe single crystal flake to be a promising magnetic material for spintronics applications.},
}

