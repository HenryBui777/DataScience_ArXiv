@misc{liMVBenchComprehensiveMultimodal2024,
  title = {{{MVBench},
  shorttitle = {{{MVBench},
  author = {Li, Kunchang and Wang, Yali and He, Yinan and Li, Yizhuo and Wang, Yi and Liu, Yi and Wang, Zun and Xu, Jilan and Chen, Guo and Luo, Ping and Wang, Limin and Qiao, Yu},
  year = {2024},
  number = {arXiv:2311.17005},
  eprint = {2311.17005},
  primaryclass = {cs},
  publisher = {arXiv},
  urldate = {2024-07-10},
  abstract = {With the rapid development of Multi-modal Large Language Models (MLLMs), a number of diagnostic benchmarks have recently emerged to evaluate the comprehension capabilities of these models. However, most benchmarks predominantly assess spatial understanding in the static image tasks, while overlooking temporal understanding in the dynamic video tasks. To alleviate this issue, we introduce a comprehensive Multi-modal Video understanding Benchmark, namely MVBench, which covers 20 challenging video tasks that cannot be effectively solved with a single frame. Specifically, we first introduce a novel staticto-dynamic method to define these temporal-related tasks. By transforming various static tasks into dynamic ones, we enable the systematic generation of video tasks that require a broad spectrum of temporal skills, ranging from perception to cognition. Then, guided by the task definition, we automatically convert public video annotations into multiplechoice QA to evaluate each task. On one hand, such a distinct paradigm allows us to build MVBench efficiently, without much manual intervention. On the other hand, it guarantees evaluation fairness with ground-truth video annotations, avoiding the biased scoring of LLMs. Moreover, we further develop a robust video MLLM baseline, i.e., VideoChat2, by progressive multi-modal training with diverse instruction-tuning data. The extensive results on our MVBench reveal that, the existing MLLMs are far from satisfactory in temporal understanding, while our VideoChat2 largely surpasses these leading models by over 15\% on MVBench. All models and data are available at https: //github.com/OpenGVLab/Ask-Anything.},
  archiveprefix = {arXiv},
  langid = {english},
  keywords = {Computer Science - Computer Vision and Pattern Recognition,videochat2},
  file = {/Users/zhangyiming/Zotero/storage/ARRAGY6F/Li 等 - 2024 - MVBench A Comprehensive Multi-modal Video Underst.pdf},
}

@misc{maazVideoChatGPTDetailedVideo2023,
  title = {Video-{{ChatGPT},
  shorttitle = {Video-{{ChatGPT},
  author = {Maaz, Muhammad and Rasheed, Hanoona and Khan, Salman and Khan, Fahad Shahbaz},
  year = {2023},
  number = {arXiv:2306.05424},
  eprint = {2306.05424},
  primaryclass = {cs},
  publisher = {arXiv},
  doi = {10.48550/arXiv.2306.05424},
  urldate = {2024-03-21},
  abstract = {Conversation agents fueled by Large Language Models (LLMs) are providing a new way to interact with visual data. While there have been initial attempts for image-based conversation models, this work addresses the underexplored field of video-based conversation by introducing Video-ChatGPT. It is a multimodal model that merges a video-adapted visual encoder with a LLM. The model is capable of understanding and generating human-like conversations about videos. We introduce a new dataset of 100,000 video-instruction pairs used to train Video-ChatGPT acquired via manual and semi-automated pipeline that is easily scalable and robust to label noise. We also develop a quantiative evaluation framework for video-based dialogue models to objectively analyse the strengths and weaknesses of proposed models. Our code, models, instruction-sets and demo are released at https://github.com/mbzuai-oryx/Video-ChatGPT.},
  archiveprefix = {arXiv},
  keywords = {Computer Science - Computer Vision and Pattern Recognition,Video-ChatGPT},
  file = {/Users/zhangyiming/Zotero/storage/6U9N58VW/Maaz 等 - 2023 - Video-ChatGPT Towards Detailed Video Understandin.pdf;/Users/zhangyiming/Zotero/storage/CHS5BT5J/2306.html},
}
