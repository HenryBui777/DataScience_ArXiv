@article{Takaoka-Tzvetkov,
  title = {{On 2d nonlinear Schrödinger equations with data on $\mathbb{R},
  journal = {Journal of Functional Analysis},
  volume = {182},
  number = {2},
  pages = {427-442},
  year = {2001},
  issn = {0022-1236},
  doi = {https://doi.org/10.1006/jfan.2000.3732},
  url = {https://www.sciencedirect.com/science/article/pii/S0022123600937327},
  author = {H Takaoka and N Tzvetkov},
  abstract = {We prove L2 global well-posedness results for 2D (subcritical and critical) nonlinear Schrödinger equations with data on R×T. We use methods of the periodic case due to J. Bourgain. The main ingredient in the proof is the L4−L2 Strichartz inequality for the free evolution which fails in the purely periodic setting.},
}
