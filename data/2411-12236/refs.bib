@article{Pandey_2024,
  author = {Akshat Pandey and Subir Ghosh},
  doi = {10.1088/1402-4896/ad8842},
  url = {https://dx.doi.org/10.1088/1402-4896/ad8842},
  journal = {Physica Scripta},
  publisher = {IOP Publishing},
  year = {2024},
  pages = {125106},
  abstract = {In this work we exploit Dirac's Constraint Analysis (DCA) in Hamiltonian formalism to study different types of Superconducting Quantum Circuits (SQC) in a unified way. The Lagrangian of a SQC reveals the constraints, that are classified in a Hamiltonian framework, such that redundant variables can be removed to isolate the canonical degrees of freedom for subsequent quantization of the Dirac Brackets via a generalized Correspondence Principle. This purely algebraic approach makes the application of concepts such as graph theory, null vector, loop charge, etc that are in vogue, (each for a specific type of circuit), completely redundant. The universal validity of DCA scheme in SQC, proposed by us, is demonstrated by correctly re-deriving existing results for different SQCs, obtained previously exploiting different formalisms each applicable for a specific SQC. Furthermore, we have also analysed and predicted new results for a generic form of SQC - it will be interesting to see its validation in an explicit circuit implementation.},
  volume = {99},
  title = {Solving superconducting quantum circuits in Dirac's constraint analysis framework*},
  month = {nov},
  number = {12},
}

@article{Korsbakken_2009,
  author = {Jan I Korsbakken and Frank K Wilhelm and K Birgitta Whaley},
  doi = {10.1088/0031-8949/2009/T137/014022},
  url = {https://dx.doi.org/10.1088/0031-8949/2009/T137/014022},
  journal = {Physica Scripta},
  publisher = {},
  year = {2009},
  pages = {014022},
  abstract = {Flux qubits, small superconducting loops interrupted by Josephson junctions, are successful realizations of quantum coherence for macroscopic variables. Superconductivity in these loops is carried by 1010 electrons, which has been interpreted as suggesting that coherent superpositions of such current states are macroscopic superpositions analogous to the state of SchrÃ¶dinger's cat. We provide a full microscopic analysis of such qubits, from which the macroscopic quantum description can be derived. This reveals that the number of microscopic constituents participating in superposition states for experimentally accessible flux qubits is surprisingly but not trivially small. The combination of this relatively small size with large differences between macroscopic observables in the two branches is seen to result from the Fermi statistics of the electrons and the large disparity between the values of superfluid and Fermi velocity in these systems.},
  volume = {2009},
  title = {Electronic structure of superposition states in flux qubits},
  month = {dec},
  number = {T137},
}
