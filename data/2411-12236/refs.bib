@article{ONISHI1966367,
  author = {Naoki Onishi and Shiro Yoshida},
  doi = {https://doi.org/10.1016/0029-5582(66)90096-4},
  url = {https://www.sciencedirect.com/science/article/pii/0029558266900964},
  issn = {0029-5582},
  journal = {Nuclear Physics},
  pages = {367-376},
  year = {1966},
  abstract = {The generator coordinate method is applied to the transition region nuclei. Using the de deformation parameter as a generator coordinate, the trial wave function is constructed by superposing shell-model wave functions with various varues of the deformation parameter. For simplicity the deformation is restricted to be axially symmetric, and the pairing correlation is taken into account by using a BCS type shell-model wave function. The generator wave function which serves as a weight function may be obtained by solving an integral equation derived through the variational principle. In the integral equation there appear overlap and energy kernels, which are matrix elements between shell-model wave functions with different values of the deformation parameter. In calculating the kernels a new method is presented. The BCS type wave function is expressed in a more suitable form to practical calculations and the matrix elements are obtained in a simple and compact form without any approximation.},
  volume = {80},
  title = {Generator coordinate method applied to nuclei in the transition region},
  number = {2},
}

