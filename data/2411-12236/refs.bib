@inbook{ref:POM,
  author = {Mila, Fr{\'e},
  doi = {10.1007/978-3-642-10589-0_20},
  url = {https://doi.org/10.1007/978-3-642-10589-0_20},
  booktitle = {Introduction to Frustrated Magnetism: Materials, Experiments, Theory},
  editor = {Lacroix, Claudine and Mendels, Philippe and Mila, Fr{\'e},
  publisher = {Springer Berlin Heidelberg},
  year = {2011},
  address = {Berlin, Heidelberg},
  pages = {537--559},
  abstract = {When looking for analytical approaches to treat frustrated quantum magnets, it is often very useful to start from a limit where the ground state is highly degenerate. This chapter discusses several ways of deriving effective Hamiltonians around such limits, starting from standard degenerate perturbation theory and proceeding to modern approaches more appropriate for the derivation of high-order effective Hamiltonians, such as the perturbative continuous unitary transformations (CUTs) or contractor renormalization (CORE). In the course of this exposition, a number of examples taken from the recent literature are discussed, including frustrated ladders and other dimer-based Heisenberg models in a field, as well as the mapping between frustrated Ising models in a transverse field and quantum dimer models (QDMs).},
  isbn = {978-3-642-10589-0},
  title = {Strong-Coupling Expansion and Effective Hamiltonians},
}

