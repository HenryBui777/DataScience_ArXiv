@article{Vlad_1984,
  title = {A time resolving spectrometry method for particles emitted in intense bursts},
  journal = {Nuclear Instruments and Methods in Physics Research Section A: Accelerators, Spectrometers, Detectors and Associated Equipment},
  volume = {227},
  number = {2},
  pages = {327-334},
  year = {1984},
  issn = {0168-9002},
