@article{Zuin2017,
  author = {M. Zuin and S. Dal Bello and L. Marrelli and M.E. Puiatti and P. Agostinetti and M. Agostini and V. Antoni and F. Auriemma and M. Barbisan and T. Barbui and M. Baruzzo and F. Belli and P. Bettini and M. Bigi and R. Bilel and M. Boldrin and T. Bolzonella and D. Bonfiglio and M. Brombin and A. Buffa and C. Bustreo and A. Canton and S. Cappello and L. Carraro and R. Cavazzana and D. Cester and L. Chacon and G. Chitarin and W.A. Cooper and L. Cordaro and M. Dalla Palma and S. Deambrosis and R. Delogu and A. De Lorenzi and G. De Masi and J.Q. Dong and D.F. Escande and A. Fassina and F. Felici and A. Ferro and C. Finotti and P. Franz and L. Frassinetti and E. Gaio and F. Ghezzi and L. Giudicotti and F. Gnesotto and M. Gobbin and W.A. Gonzalez and L. Grando and S.C. Guo and J.D. Hanson and S.P. Hirshman and P. Innocente and J.L. Jackson and S. Kiyama and M. Komm and O. Kudlacek and L. Laguardia and C. Li and B. Liu and S.F. Liu and Y.Q. Liu and D. López- Bruna and R. Lorenzini and T.C. Luce and A. Luchetta and A. Maistrello and G. Manduchi and D.K. Mansfield and G. Marchiori and N. Marconato and D. Marcuzzi and P. Martin and E. Martines and S. Martini and G. Mazzitelli and O. McCormack and E. Miorin and B. Momo and M. Moresco and Y. Narushima and M. Okabayashi and R. Paccagnella and N. Patel and M. Pavei and S. Peruzzo and N. Pilan and L. Pigatto and R. Piovan and P. Piovesan and C. Piron and L. Piron and I. Predebon and G. Pucella and C. Rea and M. Recchia and A. Rizzolo and G. Rostagni and C. Ruset and L. Sajò-Bohus and H. Sakakita and R. Sanchez and J.S. Sarff and F. Sattin and P. Scarin and O. Schmitz and W. Schneider and M. Siragusa and P. Sonato and E. Spada and S. Spagnolo and M. Spolaore and D.A. Spong and G. Spizzo and L. Stevanato and Y. Suzuki and C. Taliercio and D. Terranova and O. Tudisco and G. Urso and M. Valente and M. Valisa and M. Vallar and M. Veranda and N. Vianello and F. Villone and P. Vincenzi and N. Visonà and R.B. White and P. Xanthopoulos and X.Y. Xu and V. Yanovskiy and A. Zamengo and P. Zanca and B. Zaniol and L. Zanotto and Y. Zhang and E. Zilli},
  doi = {10.1088/1741-4326/aa61cc},
  journal = {Nuclear Fusion},
  publisher = {IOP Publishing},
  year = {2017},
  pages = {102012},
  abstract = {This paper reports the main recent results of the RFX-mod fusion science activity. The RFX-mod device is characterized by a unique flexibility in terms of accessible magnetic configurations. Axisymmetric and helically shaped reversed-field pinch equilibria have been studied, along with tokamak plasmas in a wide range of q(a) regimes (spanning from 4 down to 1.2 values). The full range of magnetic configurations in between the two, the so-called ultra-low q ones, has been explored, with the aim of studying specific physical issues common to all equilibria, such as, for example, the density limit phenomenon. The powerful RFX-mod feedback control system has been exploited for MHD control, which allowed us to extend the range of experimental parameters, as well as to induce specific magnetic perturbations for the study of 3D effects. In particular, transport, edge and isotope effects in 3D equilibria have been investigated, along with runaway mitigations through induced magnetic perturbations. The first transitions to an improved confinement scenario in circular and D-shaped tokamak plasmas have been obtained thanks to an active modification of the edge electric field through a polarized electrode. The experiments are supported by intense modeling with 3D MHD, gyrokinetic, guiding center and transport codes. Proposed modifications to the RFX-mod device, which will enable further contributions to the solution of key issues in the roadmap to ITER and DEMO, are also briefly presented.},
  volume = {57},
  title = {Overview of the {RFX-mod},
  month = {jun},
  number = {10},
}

@article{Marrelli2019,
  author = {L. Marrelli and R. Cavazzana and D. Bonfiglio and M. Gobbin and G. Marchiori and S. Peruzzo and M.E. Puiatti and G. Spizzo and D. Voltolina and P. Zanca and M. Zuin and G. Berton and P. Bettini and T. Bolzonella and A. Canton and S. Cappello and L. Carraro and L. Cordaro and S. Dal Bello and M. Dalla Palma and G. De Masi and A. Fassina and F. Gnesotto and L. Grando and P. Innocente and F. Lunardon and G. Manduchi and D. Marcuzzi and N. Marconato and R. Piovan and N. Pomaro and A. Rigoni and A. Rizzolo and P. Scarin and M. Siragusa and P. Sonato and S. Spagnolo and M. Spolaore and D. Terranova and the RFX-Mod Team},
  doi = {10.1088/1741-4326/ab1c6a},
  journal = {Nuclear Fusion},
  publisher = {IOP Publishing},
  year = {2019},
  pages = {076027},
  abstract = {RFX-mod is a Reversed Field Pinch device that allowed performing experiments in regimes with a plasma current up to 2 MA, thanks to its MHD active control system. Experiments have shown that improved plasma performances are obtained when in the resonant part of the m  =  1 spectrum one dominant tearing mode is much higher than the other secondary ones (quasi single helicity states). Tearing modes play a crucial role in determining energy and particle transport. Based on the present understanding of the interplay between passive conductive boundaries and tearing modes in an RFP, an upgrade of RFX-mod machine assembly has been designed, dubbed RFX-mod2, and it is now being implemented. The highly resistive Inconel vessel will be removed, graphite tiles will be attached to the copper stabilizing shell and the stainless steel support structure will be modified in order to be vacuum tight. In RFX-mod2, the shell-plasma proximity decreases from b/a  =  1.11 to b/a  =  1.04 and copper, instead of Inconel, will be the continuous conducting structure nearest to the plasma. MHD non-linear simulations show that secondary tearing modes amplitude and the edge bulging due to their phase locking will decrease; moreover the plasma current threshold for tearing modes wall locking will also significantly increase.},
  volume = {59},
  title = {Upgrades of the {RFX-mod},
  month = {jun},
  number = {7},
}

@article{Peruzzo2019,
  title = {Technological challenges for the design of the {RFX-mod2},
  journal = {Fusion Engineering and Design},
  volume = {146},
  pages = {692-696},
  year = {2019},
  note = {SI:SOFT-30},
  issn = {0920-3796},
  doi = {10.1016/j.fusengdes.2019.01.057},
  author = {S. Peruzzo and M. Bernardi and G. Berton and R. Cavazzana and S. {Dal Bello},
  keywords = {Vacuum vessel, Vacuum sealing, Detonation gun sprayed coatings},
  abstract = {The design of RFX-mod2 experiment implies a major change and reconfiguration of the internal components of the present machine assembly. Critical aspects of the design regard the technical solutions needed to fulfil geometrical, vacuum and electrical requirements imposed by interface with existing components and by specific operating conditions. The paper presents an overview of the design choices and the proposed implementations, assessed by means of engineering analyses and experimental tests performed on mock-ups of the new components.},
}

@article{Terranova2024,
  author = {D. Terranova and M. Agostini and F. Auriemma and M. Gobbin and G. Marchiori and L. Pigatto and P. Porcu and I. Predebon and G. Spizzo and N. Vianello and P. Zanca and D. Abate and T. Bolzonella and D. Bonfiglio and M. Bonotto and S. Cappello and L. Carraro and R. Cavazzana and P. Franz and R. Lorenzini and L. Marrelli and R. Milazzo and S. Peruzzo and M.E. Puiatti and P. Scarin and M. Spolaore and E. Tomasina and M. Valisa and M. Veranda and B. Zaniol and M. Zuin},
  doi = {10.1088/1741-4326/ad4805},
  journal = {Nuclear Fusion},
  publisher = {IOP Publishing},
  year = {2024},
  pages = {076003},
  abstract = {The RFX-mod2 installation is planned to be completed by 2024 and the start of operations is expected in 2025. The high flexibility of the machine (already tested in the previous RFX-mod experiment) allows operation in Reversed Field Pinch and tokamak configuration as well as ultra-low q pulses. In this work we present predictive analysis on transport, performances and plasma control in RFX-mod2 in view of the first experimental campaigns.},
  volume = {64},
  title = {{RFX-mod2},
  month = {may},
  number = {7},
}

@inproceedings{Listopad2024,
  author = {Aleksandr Listopad and Yanis Andrebe and Patrick Blanchard and Stefano Coda and Frederic Dolizy and Jeremie Dubray and Basil P. Duval and Damien Fasel and Ambrogio Fasoli and Remy Jacquier and Alexander N. Karpushov and Yves Martin and Dmytry Mykytchuk and Marc Noel and Olivier Sauter and Ugo Siravo and Matthieu Toussaint and David Velasco De La Fuente and TCV team},
  eventdate = {2018-09-22/2024-09-27},
  venue = {Dublin, Ireland},
  doi = {10.1016/j.fusengdes.2025.114867},
  url = {https://www.sciencedirect.com/science/article/pii/S0920379625000699},
  booktitle = {submitted to Fus. Eng. Des.},
  issn = {0920-3796},
  eventtitle = {33\textsuperscript{rd},
  journal = {Fusion Engineering and Design},
  pages = {114867},
  year = {2024},
  abstract = {The paper describes the operation and upgrade of the Heating Neutral Beam Injection (HNBI) system as well as the related infrastructure at the Tokamak Configuration Variable (TCV) during the last years. In 2023, the installation of new TCV neutron shielding was completed, enabling the operation of two deuterium heating beams at their full power for 30 (instead of 5) high-performance TCV plasma shots. The automation control capabilities of HNBIs have been enhanced through the integration of beam power scenario design into TCV discharge programming, along with real-time control of beams power based on real time plasma measurements of plasma during plasma discharge. The beam ducts were re-designed for minimization of power loads impact. The integration of thermocouples was modified for better monitoring of the ducts heating. Development of alternative ion optics for the first heating beam, designed for intermediate particle energies (up to ∼38 keV), has commenced. The first results of a beamlet geometry numerical optimization, based on beam formation IBSimu calculations, beam transportation through the duct, are considered respective the beam in-duct losses. The prototype of spectral multichannel measurement setup for beam profile scanning and species composition evaluation was tested. The first images of the beam's spectral profile, providing fractional divergence consideration, have been analyzed.},
  volume = {212},
  title = {Present status of Heating Neutral Beam Injection system at {TCV},
  keywords = {Fusion technology, Neutral beam, Ion optics, Nuclear fusion, Plasma physics, Optical diagnostics, Spectroscopy},
}

