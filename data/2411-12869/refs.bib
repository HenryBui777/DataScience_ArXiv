  author = {Johnson, Benjamin C. and Shen, Konlin and Piech, David and Ghanbari, M. Meraj and Li, Ka Yiu and Neely, Ryan and Carmena, Jose M. and Maharbiz, Michel M. and Muller, Rikky},
