  doi = {10.1109/JSSC.2021.3129993},
  abstract = {This article presents a hardware platform including stimulating implants wirelessly powered and controlled by a shared transmitter (TX) for coordinated leadless multisite stimulation. The adopted novel single-TX, multiple-implant structure can ﬂexibly deploy stimuli, improve system efﬁciency, easily scale stimulating channel quantity, and relieve efforts in device synchronization. In the proposed system, a wireless link leveraging magnetoelectric (ME) effect is co-designed with a robust and efﬁcient system-on-chip (SoC) to enable reliable operation and individual programming of every implant. Each implant integrates a 0.8-mm2 chip, a 6-mm2 ME ﬁlm, and an energy storage capacitor within a 6.2-mm3 size. ME power transfer is capable of safely transmitting milliwatt power to devices placed several centimeters away from the TX coil, maintaining good efﬁciency with size constraints, and tolerating 60◦, 1.5-cm misalignment in angular and lateral movement. The SoC robustly operates with 2-V source amplitude variations that spans a 40-mm TX-implant distance change, realizes individual addressability through physical unclonable function (PUF) IDs, and achieves 90\% efﬁciency for 1.5–3.5-V stimulation with fully programmable stimulation parameters.},
  language = {en},
  number = {3},
  urldate = {2024-04-09},
  journal = {IEEE Journal of Solid-State Circuits},
  author = {Yu, Zhanghao and Chen, Joshua C. and He, Yan and Alrashdan, Fatima T. and Avants, Benjamin W. and Singer, Amanda and Robinson, Jacob T. and Yang, Kaiyuan},
  year = {2022},
  pages = {818--830},
  file = {Yu et al. - 2022 - Magnetoelectric Bio-Implants Powered and Programme.pdf:/Users/weiwang/Zotero/storage/4M2K8ED6/Yu et al. - 2022 - Magnetoelectric Bio-Implants Powered and Programme.pdf:application/pdf},
}

