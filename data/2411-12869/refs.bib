  note = {},
  keywords = {Wireless communication, Impedance, Integrated circuits, Ultrasonic imaging, peripheral nerve, Electrodes, Transducers, ultrasound, backscatter, Backscatter, low-power wireless, neuromodulation, Stimulation},
  pages = {1--4},
