@article{Falle:2023,
  author = {Andrew Falle  and Ewan Wright  and Aaron Boley  and Michael Byers},
  doi = {10.1126/science.adi4639},
  url = {https://www.science.org/doi/abs/10.1126/science.adi4639},
  eprint = {https://www.science.org/doi/pdf/10.1126/science.adi4639},
  journal = {Science},
  pages = {150-152},
  year = {2023},
  adsnote = {Provided by the SAO/NASA Astrophysics Data System},
  abstract = {Radiofrequency filings warn of more congestion in space, but also offer possible remedies The occupation of Earth orbits by large constellations of satellites has received considerable attention in recent years. About 4500 Starlink and 630 OneWeb satellites are on orbit as of July 2023 (1), but this is only the beginning. Recent filings for radio spectrum with the International Telecommunication Union (ITU) suggest that a dramatic increase in satellite numbers is possible, much more than the tens of thousands often reported. Constellations much larger than SpaceX’s Starlink have been filed, including a 337,320-satellite constellation named Cinnamon-937 that was filed in September 2021. By treating orbital space as an unlimited resource, humanity is creating serious safety and longterm sustainability challenges to the use of low Earth orbit (LEO), including science conducted from space and the ground. The ITU filings are the warning, and also part of the solution. There is urgent need for the ITU and its member states to adopt meaningful controls.},
  adsurl = {https://ui.adsabs.harvard.edu/abs/2023Sci...382..150F},
  volume = {382},
  title = {{One million (paper) satellites},
  month = {October},
  number = {6667},
}

