@article{biswas_designer_2023,
  title = {Designer quantum states on a fractal substrate: {Compact},
  volume = {153},
  issn = {13869477},
  shorttitle = {Designer quantum states on a fractal substrate},
  url = {https://linkinghub.elsevier.com/retrieve/pii/S1386947723001121},
  doi = {10.1016/j.physe.2023.115762},
  abstract = {Compact localized single particle eigenstates on a deterministic fractal substrate, modeled by a triangular Sierpinski gasket of arbitrarily large size, are unraveled and examined analytically. We prescribe an exact real space renormalization group (RSRG) decimation scheme within a tight binding formalism to discern these states, and argue that the number of such states can be infinite if the fractal substrate is enlarged to its thermodynamic limit. Interestingly, these localized states turn out to populate the non-dispersive, flat bands in a periodic array of Sierpinski gasket motifs, however large they may be. Our results match and corroborate the recently observed compact localized, flat band states engineered on two dimensional photonic waveguide networks with a fractal geometry, and provide a whole subset of them, which, in principle, should be observable in fractal photonic lattice experiments.},
  language = {en},
  urldate = {2024-10-15},
  journal = {Physica E: Low-dimensional Systems and Nanostructures},
  author = {Biswas, Sougata and Chakrabarti, Arunava},
