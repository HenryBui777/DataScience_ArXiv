  pages = {1292--1297},
  file = {Full Text PDF:/Users/lumen/Library/Mobile Documents/com~apple~CloudDocs/Zotero/storage/8PZFAT4K/Kempkes e.a. - 2019 - Robust zero-energy modes in an electronic higher-o.pdf:application/pdf},
