@article{McCann2021,
  title = {In-situ sensing, process monitoring and machine control in Laser Powder Bed Fusion: A review},
  journal = {Additive Manufacturing},
  volume = {45},
  pages = {102058},
  year = {2021},
  issn = {2214-8604},
  doi = {https://doi.org/10.1016/j.addma.2021.102058},
  url = {https://www.sciencedirect.com/science/article/pii/S2214860421002232},
  author = {Ronan McCann and Muhannad A. Obeidi and Cian Hughes and Éanna McCarthy and Darragh S. Egan and Rajani K. Vijayaraghavan and Ajey M. Joshi and Victor {Acinas Garzon},
  keywords = {Additive manufacturing, Powder bed fusion, Process sensing, Machine control, Smart manufacturing, Selective laser melting, Electron beam melting, Industry 4.0, In-situ monitoring},
  abstract = {Process monitoring and sensing is widely used across many industries for quality assurance, and for increasing machine uptime and reliability. Though still in the emergent stages, process monitoring is beginning to see strong adoption in the additive manufacturing community through the use of process sensors recording a wide range of optical, acoustic and thermal signals. The ability to acquire these signals in a holistic manner, coupled with intelligence-based machine control has the potential to make additive manufacturing a robust and competitive alternative to conventional fabrication techniques. This paper presents an overview of the state-of the art of in-situ process monitoring in laser powder bed fusion processes and highlights some current limitations and areas for advancement. Also presented is an overview of real-time process control requirements, which when combined with the emergent process monitoring tools, will eventually allow for in-depth process control of the powder bed fusion process, which is essential for wide-scale industrial credibility and adoption of this technology.},
}

@article{Chua2024,
  title = {In-process and post-process strategies for part quality assessment in metal powder bed fusion: A review},
  journal = {Journal of Manufacturing Systems},
  volume = {73},
  pages = {75-105},
  year = {2024},
  issn = {0278-6125},
  doi = {https://doi.org/10.1016/j.jmsy.2024.01.004},
  url = {https://www.sciencedirect.com/science/article/pii/S0278612524000049},
  author = {Cherq Chua and Yanting Liu and Richard J. Williams and Chee Kai Chua and Swee Leong Sing},
  keywords = {Additive manufacturing, 3D printing, Powder bed fusion, Qualification, Post-process, In-situ monitoring},
  abstract = {An increasing number of metal components processed by additive manufacturing (AM) are now being used in industrial applications. However, in the most demanding applications, where flawless integrity is required, underpinning the quality of parts produced via AM remains a problem. Consequently, significant research activity into quality assessment methods has been conducted in recent years. In this work, the different strategies and methods for quantifying the quality of components produced via metal powder bed fusion (PBF) are reviewed. Both in-process and post-process approaches to quality assessment are considered. In-process quality assessment frameworks are based on in-situ process monitoring techniques. Different approaches are categorized according to the format of the data produced by the sensor, which aspect of quality is being measured and how the assessment is made. Metrics to quantify diagnostic accuracy, the length scale of quality assessment and in-situ repair are also discussed. Post-process methods for quality assessment are examined in the second half of the review. Methods are categorized according to the element of part quality being assessed. Both destructive and non-destructive methods are considered, including the impact on AM build design. Quality metric reporting and length scale, e.g., per build basis, per part basis or sub-regions within parts, will again be reviewed and advantages and disadvantages of post-process methods discussed.},
}
