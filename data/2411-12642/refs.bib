@article{Bode2007,
  author = {Bode, M.
and Heide, M.
and von Bergmann, K.
and Ferriani, P.
and Heinze, S.
and Bihlmayer, G.
and Kubetzka, A.
and Pietzsch, O.
and Bl{\"u},
  title = {Chiral magnetic order at surfaces driven by inversion asymmetry},
  journal = {Nature},
  year = {2007},
  month = {May},
  day = {01},
  volume = {447},
  number = {7141},
  pages = {190-193},
  abstract = {Chirality, or handedness, occurs when an object differs from its mirror image, and its mirror image cannot superimpose on the original object. Solids with chiral magnetic order could have many useful practical applications, because their novel symmetry allows the mixing of electronic, optical, magnetic and structural properties. Bode et al. have now found evidence for chiral magnetic order in a simple solid-state system: a single layer of manganese atoms on a tungsten substrate. Such chirality could be invaluable in spintronic devices, where spin rather than electron charge is used for data transmission.},
  issn = {1476-4687},
  doi = {10.1038/nature05802},
  url = {https://doi.org/10.1038/nature05802},
}

