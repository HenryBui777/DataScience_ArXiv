@article{glocerModelingIonConic2024,
  title = {Modeling {{Ion Conic Formation},
  author = {Glocer, A. and {Garcia-Sage},
  year = {2024},
  journal = {Journal of Geophysical Research: Space Physics},
  volume = {129},
  number = {4},
