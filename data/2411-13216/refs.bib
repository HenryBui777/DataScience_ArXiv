  issn = {1572-9524},
  journal = {Found Phys Lett},
  abstract = {The description of a point mass in general relativity (GR) is given in the framework of the field formulation of GR, where all the dynamical fields, including the gravitational field, are considered in a fixed background spacetime. With the use of stationary (not static) coordinates, non-singular at the horizon, the Schwarzschild solution is presented as a point-like field configuration in a whole background Minkowski space. The requirement of a stable η-causality stated recently by J. B. Pitts and W. C. Schieve (Found. Phys. 34, 211 (2004)) is used essentially as a criterion for testing configurations.},
