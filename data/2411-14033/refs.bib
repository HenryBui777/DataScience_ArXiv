  url = {https://www.sciencedirect.com/science/article/pii/S277266222300142X},
  issn = {2772-6622},
  journal = {Decision Analytics Journal},
  pages = {100302},
  year = {2023},
  abstract = {The latest developments in Artificial Intelligence (AI) are the focal point in increasing the performance of other technologies and the evolution of Industry 4.0. Considering the benefits of AI in today’s world, businesses must move towards using Integrated AI tools and services. This paper introduces a business model based on AI-as-a-Service (AIaaS), which provides an integrated bundle of AI products and services. The strategic approach, roadmap, and heuristic pricing model provided in this paper can be considered as a benchmark for AIaaS companies.},
  volume = {8},
  title = {A value-oriented Artificial Intelligence-as-a-Service business plan using integrated tools and services},
  keywords = {Artificial Intelligence-as-a-service, Industry 4.0, Machine vision, Natural language processing, Data-driven systems, Heuristic pricing},
}

