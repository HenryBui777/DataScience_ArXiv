@article{deike_air_2017,
  author = {Deike, Luc and Lenain, Luc and Melville, W. Kendall},
  doi = {10.1002/2017GL072883},
  url = {https://onlinelibrary.wiley.com/doi/abs/10.1002/2017GL072883},
  file = {Full Text PDF:C\:\\Users\\megan\\Zotero\\storage\\DC2CFGVC\\Deike et al. - 2017 - Air entrainment by breaking waves.pdf:application/pdf;Snapshot:C\:\\Users\\megan\\Zotero\\storage\\NSHG8IUV\\2017GL072883.html:text/html},
  issn = {1944-8007},
  journal = {Geophysical Research Letters},
  abstract = {We present an estimate of the total volume of entrained air by breaking waves in the open ocean, based on a model for a single breaking wave and the statistics of breaking waves measured in the field and described by the average length of breaking crests moving with speeds in the range (c,c + dc) per unit area of ocean surface, Λ(c)dc, introduced by Phillips (1985). By extending the single breaking wave model to the open ocean, we show that the volume flux of air entrained by breaking waves, VA (volume per unit ocean area per unit time, a velocity), is given by the third moment of Λ(c), modulated by a function of the wave slope. Using field measurements of the distribution Λ(c) and the wave spectrum, we obtain an estimate of the total volume flux of air entrained by breaking for a wide range of wind and wave conditions. These results pave the way for accurate remote sensing of the air entrained by breaking waves and subsequent estimates of the associated gas transfer.},
  year = {2017},
  pages = {3779--3787},
  language = {en},
  volume = {44},
  note = {\_eprint: https://onlinelibrary.wiley.com/doi/pdf/10.1002/2017GL072883},
  title = {Air entrainment by breaking waves},
  urldate = {2024-10-09},
  keywords = {air-sea interaction, bubbles, gas transfer, wave breaking},
  number = {8},
}

