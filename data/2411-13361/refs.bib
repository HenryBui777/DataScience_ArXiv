@article{Simoen2013,
  author = {Ellen Simoen and Costas Papadimitriou and Geert Lombaert},
  doi = {10.1016/j.jsv.2013.03.019},
  url = {https://linkinghub.elsevier.com/retrieve/pii/S0022460X13002514},
  issue = {18},
  issn = {0022460X},
  journal = {Journal of Sound and Vibration},
  abstract = {In Bayesian model updating, probability density functions of model parameters are updated accounting both for the information contained in the data and for uncertainties present in the measurements and model predictions, requiring a probabilistic model for the error between predictions and observations. Most often, a zero-mean uncorrelated Gaussian prediction error is assumed, although in many engineering applications prediction errors will show non-negligible spatial and/or temporal correlation (e.g. when densely populated sensor grids are used). In this paper, the effect of prediction error correlation on the results of the Bayesian model updating scheme is studied, and it is investigated how the challenging task of selecting a suitable prediction error correlation structure can be addressed appropriately. In two illustrative applications, it is demonstrated that Bayesian model class selection can be effectively applied to this end, ensuring more realistic modeling and corresponding Bayesian model updating results.},
  pages = {4136-4152},
  year = {2013},
  volume = {332},
  title = {On prediction error correlation in Bayesian model updating},
  month = {9},
}

