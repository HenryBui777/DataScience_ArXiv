@article{zuk_intrinsic_2017,
  title = {Intrinsic viscosity of macromolecules within the generalized {Rotne},
  volume = {822},
  pages = {R2},
  issn = {0022-1120, 1469-7645},
  doi = {10.1017/jfm.2017.264},
  abstract = {We develop a generalized Rotne–Prager–Yamakawa approximation for the dipolar components of the inverse friction matrix and use it for calculating the intrinsic viscosity of rigidly connected bead conglomerates. Such bead models are commonly used in the calculation of hydrodynamic properties of macromolecules. We consider both the case of non-overlapping constituent beads as well as overlapping beads of different sizes. We demonstrate the accuracy of the approximation in two test cases and show that it performs well even if the distances between the beads are small or if the beads overlap. Robust performance of this approximation in the case of overlapping beads stems from its correct limiting behaviour at a complete overlap, with one sphere fully immersed in the other. The generalized Rotne–Prager–Yamakawa approximation is thus well suited for evaluation of intrinsic viscosity, which is a key quantity in characterizing molecular conformations of biological macromolecules.},
  language = {en},
  urldate = {2021-01-26},
  journal = {J. Fluid Mech.},
  ignoreauthor = {Zuk, Pawel J. and Cichocki, Bogdan and Szymczak, Piotr},
  author = {Zuk, P. J. and Cichocki, B. and Szymczak, P.},
  year = {2017},
  keywords = {complex fluids, low-Reynolds-number flows, mathematical foundations},
}

