  year = {1980},
  abstract = {P- and T-invariance violation in quantum chromodynamics due to the so-called Î¸-term is discussed. It is shown that irrespectively of how the confinement works there emerge observable P- and T-odd effects. The proof is based on the assumption that QCD resolves the U(1) problem, i.e., the mass of the singlet pseudoscalar meson does not vanish in the chiral limit. We suggest a modification of the axion scheme which restores the natural P and T invariance of the theory and cannot be ruled out experimentally.},
  volume = {166},
  title = {Can confinement ensure natural {CP},
  number = {3},
}

