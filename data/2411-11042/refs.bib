@article{lhuillier_high-order_1993,
  author = {L’Huillier, Anne and Lewenstein, M. and Salières, P. and Balcou, Ph. and Ivanov, M. Yu. and Larsson, J. and Wahlström, C. G.},
  doi = {10.1103/PhysRevA.48.R3433},
