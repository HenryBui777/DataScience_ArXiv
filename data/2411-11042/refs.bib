@article{antoine_theory_1996,
  author = {Antoine, Philippe and L’Huillier, Anne and Lewenstein, Maciej and Salières, Pascal and Carré, Bertrand},
  doi = {10.1103/PhysRevA.53.1725},
  url = {https://link.aps.org/doi/10.1103/PhysRevA.53.1725},
