@article{dudovich_attosecond_2006,
  author = {Dudovich, N. and Levesque, J. and Smirnova, O. and Zeidler, D. and Comtois, D. and Ivanov, M. Yu. and Villeneuve, D. M. and Corkum, P. B.},
  doi = {10.1103/PhysRevLett.97.253903},
