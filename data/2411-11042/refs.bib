@article{corkum_subfemtosecond_1994,
  author = {Corkum, P. B. and Burnett, N. H. and Ivanov, M. Y.},
  doi = {10.1364/OL.19.001870},
  url = {https://opg.optica.org/ol/abstract.cfm?uri=ol-19-22-1870},
  copyright = {© 1994 Optical Society of America},
  issn = {1539-4794},
