  journal = {Geophysical Research Letters},
  title = {Electron holes and heating in the reconnection dissipation region},
  year = {2010},
  issn = {1944-8007},
  number = {11},
  volume = {37},
  abstract = {Using particle-in-cell simulations and kinetic theory, we explore the current-driven turbulence and associated electron heating in the dissipation region during 3D magnetic reconnection with a guide field. At late time the turbulence is dominated by the Buneman and lower hybrid instabilities. Both produce electron holes that co-exist but have very different propagation speeds. The associated scattering of electrons by the holes enhances electron heating in the dissipation region.},
  copyright = {Copyright 2010 by the American Geophysical Union.},
  doi = {10.1029/2010GL043608},
  file = {Full Text PDF:https\://onlinelibrary.wiley.com/doi/pdfdirect/10.1029/2010GL043608:application/pdf},
  keywords = {magnetic reconnection, electron heating, electron holes},
  url = {https://onlinelibrary.wiley.com/doi/abs/10.1029/2010GL043608},
  urldate = {2024-09-20},
}

