@incollection{ROUPHAEL2014179,
  author = {Tony J. Rouphael},
  doi = {https://doi.org/10.1016/B978-0-12-378640-1.00004-4},
  url = {https://www.sciencedirect.com/science/article/pii/B9780123786401000044},
  booktitle = {Wireless Receiver Architectures and Design},
  editor = {Tony J. Rouphael},
  publisher = {Academic Press},
  pages = {179-261},
  address = {Boston},
  year = {2014},
  isbn = {978-0-12-378640-1},
  abstract = {Analysis developed using linear algebraic tools, such as scattering parameters, is essentially used to perform linear analysis of radio frequency (RF) networks. Circuits that exhibit nonlinearity with or without memory cannot be simply analyzed using linear techniques to sufficiently characterize their performance. In practice, both linear and nonlinear techniques are used for analysis, simulation, and design. Nonlinear networks, on the other hand, depending on their instantiation within the receiver, have to be treated with the appropriate nonlinear techniques. These nonlinear techniques are the subject of this chapter. In a similar manner, if several nonlinear systems or circuits are presented in cascade, for example, the circuit itself as a whole can be modeled as a cascade of linear and nonlinear elements.},
  title = {Chapter 4 - System Nonlinearity},
  keywords = {Compression points, Harmonic input method, 2, 3, Memoryless nonlinearity, Nonlinear systems with memory, Volterra series},
}

@incollection{SUAREZ201665,
  author = {A. Suarez and S. Sancho and F. Ramirez},
  doi = {https://doi.org/10.1016/B978-0-12-803894-9.00003-2},
  url = {https://www.sciencedirect.com/science/article/pii/B9780128038949000032},
  booktitle = {Microwave Wireless Communications},
  editor = {Antonio Raffo and Giovanni Crupi},
  publisher = {Academic Press},
  pages = {65-133},
  year = {2016},
  isbn = {978-0-12-803894-9},
  abstract = {This chapter will cover all the main aspects of oscillator analysis and design. Essential concepts are presented, such as the mechanism for the oscillation start-up from an unstable dc solution, the coexistence of the oscillatory steady-state solution with the dc solution, and the invariance of the periodic steady-state solution under time shifts. Then a harmonic-balance methodology for nonlinear oscillator design is described. Stability analysis is fundamental in oscillator circuits, since two different steady-state solutions, dc and periodic, necessarily coexist. The foundations of this stability analysis will be presented in depth, as well as the main types of bifurcations, or qualitative stability changes, observed in oscillator circuits under the continuous variation of a circuit parameter. Three major methodologies for phase-noise analysis will be described, discussing their advantages and limitations. Finally, a procedure to extract a reduced-order model of the oscillator circuit from harmonic-balance simulations will be presented, with application examples in coupled-oscillator systems and phase-locked loops.},
  title = {Chapter 3 - Nonlinear analysis and design of oscillator circuits},
  keywords = {Microwave oscillators, Stability analysis, Phase noise},
}

@incollection{WANG202327,
  author = {Xuechuan Wang and Xiaokui Yue and Honghua Dai and Haoyang Feng and Satya N. Atluri},
  doi = {https://doi.org/10.1016/B978-0-323-99113-1.00002-9},
  url = {https://www.sciencedirect.com/science/article/pii/B9780323991131000029},
  booktitle = {Computational Methods for Nonlinear Dynamical Systems},
  editor = {Xuechuan Wang and Xiaokui Yue and Honghua Dai and Haoyang Feng and Satya N. Atluri},
  publisher = {Elsevier},
  pages = {27-54},
  year = {2023},
  isbn = {978-0-323-99113-1},
  abstract = {In this chapter we take the Duffing equation as example to illustrate that the subharmonic oscillations (when the period of the forcing function is nearly three times the natural frequency of the linear system) can be captured by using the time collocation method over a period, assuming harmonic as well as subharmonic Fourier series as the trial functions. We show that the present simple notion of collocation of the error in the nonlinear ODE, with the assumed trial functions, is entirely equivalent to the high-dimensional harmonic balance (HDHB) method or the time domain harmonic balance (HB) method.},
  title = {Chapter 2 - Harmonic balance method and time domain collocation method},
  keywords = {Harmonic, spatial, oscillators, collocation, domain},
}

