@inproceedings{larsson_optimal_2019,
  title = {Optimal {Trilateration},
  doi = {10.1109/ICASSP.2019.8683355},
  abstract = {The problem of estimating receiver or sender node positions from measured receiver-sender distances is a key issue in different applications such as microphone array calibration, radio antenna array calibration, mapping and positioning using UWB or using round-trip-time measurements between mobile phones and WiFi-units. In this paper we address the problem of optimally estimating a receiver position given a number of distance measurements to known sender positions, so called trilateration. We show that this problem can be rephrased as an eigenvalue problem. We also address different error models and the multilateration setting where an additional offset is also unknown, and show that these problems can be modeled using the same framework.},
  booktitle = {{ICASSP},
  author = {Larsson, M. and Larsson, V. and {\AA},
  year = {2019},
  note = {ISSN: 2379-190X},
  keywords = {time-of-arrival estimation, optimisation, calibration, Calibration, wireless LAN, Trilateration, antenna arrays, distance measurement, distance measurements, eigenvalue problem, eigenvalues and eigenfunctions, error models, microphone array calibration, microphone arrays, mobile handsets, mobile phones, Multilateration, multilateration setting, Optimal estimation, optimal trilateration, radio antenna array calibration, receiver position, receiver-sender distances, round-trip-time measurements, sender positions, WiFi-units},
  pages = {5586--5590},
  file = {Larsson et al. - 2019 - Optimal Trilateration Is an Eigenvalue Problem.pdf:C\:\\Users\\Martin\\Zotero\\storage\\S6VP96VX\\Larsson et al. - 2019 - Optimal Trilateration Is an Eigenvalue Problem.pdf:application/pdf},
}

