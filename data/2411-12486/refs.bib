@article{AGUIRRE20241354450,
  title = {Vortex state in a {3D},
  journal = {Phys. C Supercond.},
  volume = {618},
  pages = {1354450},
  year = {2024},
  issn = {0921-4534},
  doi = {https://doi.org/10.1016/j.physc.2024.1354450},
  url = {https://www.sciencedirect.com/science/article/pii/S0921453424000157},
  author = {C.A. Aguirre and P. Díaz and D. Laroze and A.S. Mosquera Polo and J. Barba-Ortega},
  keywords = {Vortex, Magnetization, Ginzburg–Landau theory, Demagnetization, Wedge, Mesoscopics, deGennes-parameter},
  abstract = {In the present paper, we study the effect of the boundary conditions (deGennes-parameter b) on the magnetization (M), critical fields (H1,H2), and Cooper pair density (|ψ|2) in a three-dimensional superconducting meso-wedge, solving the time-dependent Ginzburg–Landau equations TDGL. These equations are solved by taking into account the demagnetization effects. We show that the slope of the superconducting meso-wedge can be used to control the vortex (fluxoids Φ) configurations, such as the side through which the magnetic flux enters the sample.},
}

@article{peng_2016,
  title = {Vortex {States},
  volume = {29},
  issn = {1557-1947},
  url = {https://doi.org/10.1007/s10948-016-3420-7},
  doi = {10.1007/s10948-016-3420-7},
  abstract = {The time-dependent Ginzburg–Landau equations have been solved numerically by the finite-element method for a three-dimensional mesoscopic superconducting torus. We obtain the different vortex patterns as a function of the applied field perpendicular to its surface. And we find that multivortex states are ground state in a three-dimensional mesoscopic torus. These results show that our approach is effective and useful to interpret experimental data on vortex states in mesoscopic superconductors.},
