  file = {/home/matthew/.zotero/zotero/pv7002m9.default/zotero/storage/FUBN4FYW/Hicks et al. - 2019 - The AFLOW Library of Crystallographic Prototypes .pdf;/home/matthew/.zotero/zotero/pv7002m9.default/zotero/storage/7DPSKUK5/S0927025618307146.html},
