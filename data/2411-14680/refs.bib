@article{dshemuchadse_moving_2021,
  ids = {dshemuchadse_beyond_2019,dshemuchadse_moving_2021-1},
  title = {Moving beyond the Constraints of Chemistry via Crystal Structure Discovery with Isotropic Multiwell Pair Potentials},
  author = {Dshemuchadse, Julia and Damasceno, Pablo F. and Phillips, Carolyn L. and Engel, Michael and Glotzer, Sharon C.},
  year = {2021},
  journal = {Proceedings of the National Academy of Sciences},
  volume = {118},
  number = {21},
  publisher = {National Academy of Sciences},
  issn = {0027-8424, 1091-6490},
  doi = {10.1073/pnas.2024034118},
  urldate = {2021-05-17},
  abstract = {The rigid constraints of chemistry---dictated by quantum mechanics and the discrete nature of the atom---limit the set of observable atomic crystal structures. What structures are possible in the absence of these constraints? Here, we systematically crystallize one-component systems of particles interacting with isotropic multiwell pair potentials. We investigate two tunable families of pairwise interaction potentials. Our simulations self-assemble a multitude of crystal structures ranging from basic lattices to complex networks. Sixteen of the structures have natural analogs spanning all coordination numbers found in inorganic chemistry. Fifteen more are hitherto unknown and occupy the space between covalent and metallic coordination environments. The discovered crystal structures constitute targets for self-assembly and expand our understanding of what a crystal structure can look like.},
  chapter = {Physical Sciences},
  copyright = {{\copyright},
  langid = {english},
  pmid = {34001591},
  keywords = {crystal structures,isotropic pair potentials,self-assembly},
  file = {/home/matthew/.zotero/zotero/pv7002m9.default/zotero/storage/E6277QDX/Dshemuchadse et al. - 2021 - Moving beyond the constraints of chemistry via cry.pdf;/home/matthew/.zotero/zotero/pv7002m9.default/zotero/storage/FLM2ADSC/pnas.2024034118.sapp.pdf;/home/matthew/.zotero/zotero/pv7002m9.default/zotero/storage/QBXRMWHD/Dshemuchadse et al. - Beyond the constraints of chemistry crystal struc.pdf;/home/matthew/.zotero/zotero/pv7002m9.default/zotero/storage/SF6WP9NS/Dshemuchadse et al. - 2021 - Moving beyond the constraints of chemistry via cry.pdf;/home/matthew/.zotero/zotero/pv7002m9.default/zotero/storage/6X2TNJ2Y/e2024034118.html},
