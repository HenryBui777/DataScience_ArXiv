                   subtropical edge of the HC to shift poleward by up to
                   3{$^\circ$},
  doi = {10.1175/JCLI-D-18-0324.1},
  issn = {0894-8755},
}

@article{watt-meyer_itcz_2019,
  author = {{Watt-Meyer},
  journal = {Journal of Climate},
  number = {4},
  pages = {1151--1166},
