  author = {Cronin, Austin and Tkaczyk, Eric R. and Hussain, Iftak and Bowden, Audrey and Saknite, Inga},
  title = {Effect of camera distance and angle on color of diverse skin tone-based standards in smartphone photos},
  journal = {Journal of Biophotonics},
