@article{PARK2021130359,
  title = {Smartphone-based colorimetric analysis of structural colors from pH-responsive photonic gel},
  journal = {Sensors and Actuators B: Chemical},
  volume = {345},
  pages = {130359},
  year = {2021},
  issn = {0925-4005},
  doi = {https://doi.org/10.1016/j.snb.2021.130359},
  url = {https://www.sciencedirect.com/science/article/pii/S0925400521009278},
  author = {Habeen Park and Young Gook Koh and Wonmok Lee},
  keywords = {Colorimetry, Hue parameter, Structural color, Photonic gel, Smartphone},
  abstract = {We report a smartphone-based colorimetric analysis of an inverse opal photonic gel (IOPG) sensor that exhibits reversible color changes corresponding to a specific analyte. Herein, pH-responsive IOPG sensors containing a copolymer including poly(acrylic acid) were fabricated by opal-templated photopolymerization. The structural colors of an IOPG sensor templated by a 235 nm-sized microsphere changed from green to red upon increasing the pH, and the colors of a 200 nm microsphere sensor changed from blue to green. Up to now, UV–vis spectrometry has been commonly used for precision analysis to obtain a reflectance spectrum from an IOPG and for a subsequent peak analysis. However, a typical spectrometer comprises benchtop equipment that is bulky, expensive, and often time-consuming to use. Therefore, we investigated a smartphone-based mobile sensing approach as a simple, inexpensive, and rapid alternative to the conventional method by leveraging its built-in functions. In this approach, we use the hue (H) parameter in HSV color space instead of RGB color coordinates which are not directly related to the wavelengths of the visible light spectrum. Through rigorous examinations, the smartphone-based H analysis of the IOPG sensor was found to be applicable with reasonable precision under common illuminations such as fluorescent light, LED, or the built-in flash of a smartphone. Both green-red and blue-green IOPGs showed similar reliability in the colorimetric determination of pH in the range of interest. Results suggest that there was no significant dependence of the colorimetric analysis on smartphones from different companies.},
}

@article{CAOskinsmartphone,
  title = {Preferred skin tones on mobile displays under illuminants having different correlated colour temperatures},
  journal = {Vision Research},
  volume = {198},
  pages = {108060},
  year = {2022},
  issn = {0042-6989},
  doi = {https://doi.org/10.1016/j.visres.2022.108060},
  url = {https://www.sciencedirect.com/science/article/pii/S0042698922000669},
  author = {Mingkai Cao and Ming Ronnier Luo},
  keywords = {Skin tone boundary, Preferred skin tone, Colour reproduction, Skin types},
  abstract = {A psychophysical experiment was conducted to investigate preferred skin tones of 4 skin types under 5 illuminants varying in correlated colour temperatures. The experiments were performed on calibrated mobile display devices. Four facial skin tone images representing each skin type were captured and were rendered to 25 skin tone images to cover a large colour region. The facial skin tone images were assessed by a panel of 28 Chinese observers using an alternative forced choice psychophysical method. The ellipses based on observer preference rate were derived, and the preferred skin tone centres and 50% tolerance ellipse of different skin types under each test illuminants were obtained. According to the colour appearance shift of preferred skin tones under illuminants with varying CCTs, all data were transformed and compared in the a*b* plane under D65 and CIE 1931 Standard Colorimetric Observer condition. The results on the impact of illuminants on preferred skin tones were reported here. All types of skin tones had a good agreement under different illuminants.},
}

@article{smartphoneurine,
  author = {Muhaimin Noor Azhar and Aida Bustam and Fathmath Sausan Naseem and Soo Siew Shuin and Mohd Hafyzuddin Md Yusuf and Naseeha Ubaidi Hishamudin and Khadijah Poh},
  title = {Improving the reliability of smartphone-based urine colorimetry using a colour card calibration method},
  journal = {DIGITAL HEALTH},
  volume = {9},
  number = {},
  pages = {20552076231154684},
  year = {2023},
  doi = {10.1177/20552076231154684},
  url = {https://doi.org/10.1177/20552076231154684},
  eprint = {https://doi.org/10.1177/20552076231154684},
  abstract = {ObjectiveUrine colorimetry using a digital image–based colorimetry is potentially an accessible hydration assessment method. This study evaluated the agreement between urine colorimetry values measured with different smartphone brands under various lighting conditions in patients with dengue fever.MethodsThe urine samples were photographed in a customized photo box, under five simulated lighting conditions, using five smartphones. These images were analyzed using Adobe Photoshop to obtain urine Red, Green and Blue (RGB) values with and without colour correction. A commercially available colour calibration card was used for colour correction. Using intraclass correlation coefficient (ICC), inter-phone and intra-phone agreements of urine RGB values were analyzed.ResultsWithout colour correction, the various smartphones produced the highest agreement for Blue and Green values under the ‘daylight’ lighting condition. With colour correction, ICC values showed ‘exceptional’ inter-phone and intra-phone agreement for the Blue and Green values (ICC > 0.9). Red values showed ‘poor’ (ICC < 0.5) agreement with and without colour correction in all lighting conditions. Out of the five phones compared in this study, Phone 4 produced the lowest intra-phone agreement.ConclusionsColour calibration using photo colour cards improved the reliability of smartphone-based urine colorimetry, making this a promising point-of-care hydration assessment tool using the ubiquitous smartphone.},
}

