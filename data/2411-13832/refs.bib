  doi = {https://doi.org/10.1002/jbio.202200381},
  url = {https://onlinelibrary.wiley.com/doi/abs/10.1002/jbio.202200381},
  eprint = {https://onlinelibrary.wiley.com/doi/pdf/10.1002/jbio.202200381},
  abstract = {Abstract Accurate and reproducible color capture is vital in medical photography. Camera distance and angle are particularly important as they are highly variable in a clinical setting. To account for variability in illumination, camera technology, and geometric effects, color standards are often used for color correction. To explore how geometry affects color, we quantified the change in CIELAB color value of a color standard for diverse skin tones at varying smartphone camera distances and angles. Whereas both chromaticity (a* and b*) and lightness (L*) were affected by angle, distance only affected L* (standard error of measurement, SEM > 1 CIELAB unit). Flash usage did not generally reduce distance and angle associated variability. Compared to compressed (JPG) format, raw (DNG) images had decreased median variability across different distances and angles. These findings suggest that in medical photography, inconsistent camera distance and angle can increase variability in photographed skin appearance over time.},
  year = {2023},
}

