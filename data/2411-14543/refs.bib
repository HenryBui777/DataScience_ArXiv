  doi = {10.1088/0305-4470/17/17/005},
  journal = {Journal of Physics A: Mathematical and General},
  groups = {older},
  pages = {L933},
  year = {1984},
  abstract = {The prediction of conformal invariance for the statistics of self-avoiding random walks restricted to both semi-infinite and wedge-shaped geometries are tested by extrapolating exact enumerations. Close agreement is found, both for the angular distribution of the end-to-end vector, and for the dependence of the critical exponent gamma 2 on the opening angle of the wedge.},
