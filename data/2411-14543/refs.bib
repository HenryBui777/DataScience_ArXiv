@article{Drukker2020,
  author = {Nadav Drukker and Malte Probst and Maxime Trépanier},
  doi = {10.1088/1751-8121/aba1b7},
  journal = {Journal of Physics A: Mathematical and Theoretical},
  groups = {addendum},
  pages = {365401},
  year = {2020},
  abstract = {The 6d  theory has natural surface operator observables, which are akin in many ways to Wilson loops in gauge theories. We propose a definition of a ‘locally BPS’ surface operator and study its conformal anomalies, the analog of the conformal dimension of local operators. We study the abelian theory and the holographic dual of the large N theory refining previously used techniques. Introducing non-constant couplings to the scalar fields allows for an extra anomaly coefficient, which we find in both cases to be related to one of the geometrical anomaly coefficients, suggesting a general relation due to supersymmetry. We also comment on surfaces with conical singularities.},
  publisher = {IOP Publishing},
  volume = {53},
  title = {{Surface operators in the 6d N = (2, 0) theory},
  month = {aug},
  number = {36},
}

