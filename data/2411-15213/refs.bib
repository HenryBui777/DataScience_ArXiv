@article{KOPRIVOVA2024-diffusion-review,
  title = {Possibilities of Using Multi-b-value Diffusion Magnetic Resonance Imaging for Classification of Brain Lesions},
  journal = {Academic Radiology},
  volume = {31},
  number = {1},
  pages = {261-272},
  year = {2024},
  issn = {1076-6332},
  doi = {https://doi.org/10.1016/j.acra.2023.10.002},
  url = {https://www.sciencedirect.com/science/article/pii/S1076633223005378},
  author = {Tereza Kopřivová and Miloš Keřkovský and Tomáš Jůza and Václav Vybíhal and Tomáš Rohan and Michal Kozubek and Marek Dostál},
  keywords = {DWI, IVIM, DKI, Brain tumours},
  abstract = {In contrast to conventional diffusion magnetic resonance imaging (MRI), multi-b-value diffusion MRI methods are able to separate the signal from free water, pseudo-diffusion, and non-Gaussian components of water molecule diffusion. These approaches can then be utilised in so-called intravoxel incoherent motion imaging and diffusion kurtosis imaging. Various parameters provided by these methods can describe additional characteristics of the tissue microstructure and potentially help in the diagnosis and classification of various pathological processes. In this review, we present the basic principles and methods of analysing multi-b-value diffusion imaging data and specifically focus on the known possibilities for its use in the diagnosis of brain lesions. We also suggest possible directions for further research.},
}
