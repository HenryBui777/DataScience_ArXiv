@misc{ramezani_aerobat_2022,
  title = {Aerobat, {A},
  url = {http://arxiv.org/abs/2212.05361},
  doi = {10.48550/arXiv.2212.05361},
  abstract = {This work presents an actuation framework for a bioinspired flapping drone called Aerobat. This drone, capable of producing dynamically versatile wing conformations, possesses 14 body joints and is tail-less. Therefore, in our robot, unlike mainstream flapping wing designs that are open-loop stable and have no pronounced morphing characteristics, the actuation, and closed-loop feedback design can pose significant challenges. We propose a framework based on integrating mechanical intelligence and control. In this design framework, small adjustments led by several tiny low-power actuators called primers can yield significant flight control roles owing to the robot's computational structures. Since they are incredibly lightweight, the system can host the primers in large numbers. In this work, we aim to show the feasibility of joint's motion regulation in Aerobat's untethered flights.},
  urldate = {2023-05-17},
  publisher = {arXiv},
  author = {Ramezani, Alireza and Sihite, Eric},
  year = {2022},
  note = {arXiv:2212.05361 [cs, eess]},
