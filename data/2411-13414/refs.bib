@article{Dieter2012,
  title = {3D FEM–BEM-coupling method to solve magnetostatic Maxwell equations},
  journal = {J. Magn. Magn. Mater.},
  volume = {324},
  number = {10},
  pages = {1862-1866},
  year = {2012},
  doi = {https://doi.org/10.1016/j.jmmm.2012.01.016},
  author = {Florian Bruckner and Christoph Vogler and Michael Feischl and Dirk Praetorius and Bernhard Bergmair and Thomas Huber and Markus Fuger and Dieter Suess},
  keywords = {FEM–BEM coupling, Johnson–Nédélec method, ACA+, Preconditioner, Magnetostatic Maxwell equation, Scalar potential},
  abstract = {3D magnetostatic Maxwell equations are solved using the direct Johnson–Nédélec FEM–BEM coupling method and a reduced scalar potential approach. The occurring BEM matrices are calculated analytically and approximated by H-matrices using the ACA+ algorithm. In addition a proper preconditioning method is suggested that allows to solve large-scale problems using iterative solvers.},
}
