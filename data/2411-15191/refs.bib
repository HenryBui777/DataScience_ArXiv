@article{KLINE2019128,
  title = {Properties of the d-dimensional earth mover’s problem},
  journal = {Discrete Appl. Math.},
  volume = {265},
  pages = {128-141},
  year = {2019},
  issn = {0166-218X},
  doi = {https://doi.org/10.1016/j.dam.2019.02.042},
  opturl = {https://www.sciencedirect.com/science/article/pii/S0166218X19301441},
  author = {Jeffery Kline},
  keywords = {Submodularity, Monge Property, Linear Programming, Greedy Algorithm, Transportation Problem, Convex Polytopes},
  abstract = {The optimal value of the objective function of the d-dimensional earth mover’s problem can be viewed as a real-valued functional ϕ that is defined on normalized and finite multisets X⊂R+n. We show that ϕ possesses a variety of useful properties: it is homogeneous, translation invariant, it has a monotonicity property of the form convX⊂convY implies ϕX≤ϕY and ϕ is Minkowski additive, i.e., ϕX+Y=ϕX+ϕY. We also show that for admissible X, solutions to the primal and dual linear programs that define ϕ may be generated simultaneously using a single-phase greedy algorithm and that solutions to the dual reflect the geometry of X.},
}

