@article{whitaker_hubble_2019,
  author = {Whitaker, Katherine E. and Ashas, Mohammad and Illingworth, Garth and Magee, Daniel and Leja, Joel and Oesch, Pascal and van Dokkum, Pieter and Mowla, Lamiya and Bouwens, Rychard and Franx, Marijn and Holden, Bradford and Labbé, Ivo and Rafelski, Marc and Teplitz, Harry and Gonzalez, Valentino},
