@article{kroupa_variation_2001,
  author = {Kroupa, Pavel},
  doi = {10.1046/j.1365-8711.2001.04022.x},
  url = {https://ui.adsabs.harvard.edu/abs/2001MNRAS.322..231K},
  issn = {0035-8711},
  journal = {Monthly Notices of the Royal Astronomical Society},
  abstract = {A universal initial mass function (IMF) is not intuitive, but so far no convincing evidence for a variable IMF exists. The detection of systematic variations of the IMF with star-forming conditions would be the Rosetta Stone for star formation. In this contribution an average or Galactic-field IMF is defined, stressing that there is evidence for a change in the power-law index at only two masses: near 0.5Msolar and near 0.08Msolar. Using this supposed universal IMF, the uncertainty inherent in any observational estimate of the IMF is investigated by studying the scatter introduced by Poisson noise and the dynamical evolution of star clusters. It is found that this apparent scatter reproduces quite well the observed scatter in power-law index determinations, thus defining the fundamental limit within which any true variation becomes undetectable. The absence of evidence for a variable IMF means that any true variation of the IMF in well-studied populations must be smaller than this scatter. Determinations of the power-law indices α are subject to systematic errors arising mostly from unresolved binaries. The systematic bias is quantified here, with the result that the single-star IMFs for young star clusters are systematically steeper by Δα{\textasciitilde},
  year = {2001},
  pages = {231--246},
  volume = {322},
  note = {Publisher: OUP
ADS Bibcode: 2001MNRAS.322..231K},
  title = {On the variation of the initial mass function},
