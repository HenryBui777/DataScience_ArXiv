@misc{jia_driveadapter_2023,
  title = {{{DriveAdapter},
  shorttitle = {{{DriveAdapter},
  author = {Jia, Xiaosong and Gao, Yulu and Chen, Li and Yan, Junchi and Liu, Patrick Langechuan and Li, Hongyang},
  year = {2023},
  number = {arXiv:2308.00398},
