@incollection{arai_agent-based_2019,
  title = {An {{Agent-Based Modelling Framework},
  booktitle = {Intelligent {{Systems},
  author = {De Silva, Varuna and Wang, Xiongzhao and Aladagli, Deniz and Kondoz, Ahmet and Ekmekcioglu, Erhan},
