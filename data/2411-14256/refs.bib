  file = {arXiv Fulltext PDF:/home/dantong/Zotero/storage/Q5EXU7TC/Dosovitskiy et al. - 2021 - An Image is Worth 16x16 Words Transformers for Im.pdf:application/pdf;arXiv.org Snapshot:/home/dantong/Zotero/storage/IU2WPG84/2010.html:text/html},
