  url = {https://gmd.copernicus.org/articles/8/3393/2015/gmd-8-3393-2015.html},
  doi = {10.5194/gmd-8-3393-2015},
  abstract = {We examine the influence of the grid aspect ratio of horizontal to vertical grid spacing on turbulence in the planetary boundary layer (PBL) in a large-eddy simulation (LES). In order to clarify and distinguish them from other artificial effects caused by numerical schemes, we used a fully compressible meteorological LES model with a fully explicit scheme of temporal integration. The influences are investigated with a series of sensitivity tests with parameter sweeps of spatial resolution and grid aspect ratio. We confirmed that the mixing length of the eddy viscosity and diffusion due to sub-grid-scale turbulence plays an essential role in reproducing the theoretical \&minus;5/3 slope of the energy spectrum. If we define the filter length in LES modeling based on consideration of the numerical scheme, and introduce a corrective factor for the grid aspect ratio into the mixing length, the theoretical slope of the energy spectrum can be obtained; otherwise, spurious energy piling appears at high wave numbers. We also found that the grid aspect ratio has influence on the turbulent statistics, especially the skewness of the vertical velocity near the top of the PBL, which becomes spuriously large with large aspect ratio, even if a reasonable spectrum is obtained.},
  number = {10},
  urldate = {2024-04-11},
  journal = {Geoscientific Model Development},
  author = {Nishizawa, S. and Yashiro, H. and Sato, Y. and Miyamoto, Y. and Tomita, H.},
  year = {2015},
  note = {Publisher: Copernicus GmbH},
  pages = {3393--3419},
  file = {Full Text PDF:H\:\\Seafile\\刘焕聪的资料库\\Zotero_data\\storage\\ZE7GQZSF\\Nishizawa 等 - 2015 - Influence of grid aspect ratio on planetary bounda.pdf:application/pdf},
}

