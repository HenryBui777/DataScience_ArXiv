@article{Ribsteinetal2022,
  author = {Ribstein, B. and Millet, C. and Lott, F. and de la Cámara, A.},
  title = {Can We Improve the Realism of Gravity Wave Parameterizations by Imposing Sources at All Altitudes in the Atmosphere?},
  journal = {Journal of Advances in Modeling Earth Systems},
  volume = {14},
  number = {2},
  pages = {e2021MS002563},
  keywords = {gravity waves, parameterization, climate model, middle atmosphere},
  doi = {https://doi.org/10.1029/2021MS002563},
  url = {https://agupubs.onlinelibrary.wiley.com/doi/abs/10.1029/2021MS002563},
  eprint = {https://agupubs.onlinelibrary.wiley.com/doi/pdf/10.1029/2021MS002563},
  note = {e2021MS002563 2021MS002563},
  abstract = {Abstract A multiwave non-orographic gravity wave (GW) scheme is adapted to represent waves of small intrinsic phase speed, inertial waves, and wave emission from all altitudes. This last change removes the launching altitude parameter, an arbitrary parameter systematically used in GW schemes. In offline calculations using reanalysis fields, these changes impose larger amplitude, saturated waves everywhere in the middle atmosphere, which produces more realistic GW vertical spectra than in previous configurations. The same scheme, tested online in the Laboratoire de Météorologie Dynamique Zoom (LMDz) general circulation model, performs at least as well as the operational non-orographic GW scheme. Some modest benefits are seen, for instance, in the equatorial tilt with altitude of the winter jets in the middle atmosphere. Although the scheme includes the effects of inertial waves, which are detected in the mesosphere by different observational platforms, the configuration that gives a reasonable climatology in LMDz hinders their vertical propagation and limits their presence at mesospheric altitudes.},
  year = {2022},
}

