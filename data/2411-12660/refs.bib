  doi = {10.1049/ree.1977.0079},
  urldate = {2024-11-13},
  abstract = {The main application for channel electron multipliers is in the production of compact, high-gain image intensifiers. The channel plate has certain unique characteristics which influence the design of the intensifier and the performance of the finished device. It is the purpose of this paper to relate the characteristics of the channel plate to the demands of the tube with particular reference to image resolution, noise and tube life. The introduction of the channel plate into an image device is not without its problems. Some of these are discussed together with various solutions which have been adopted and their consequent effects on tube performance are described.},
