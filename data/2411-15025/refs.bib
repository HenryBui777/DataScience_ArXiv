@article{AdiabaticMicroringResonators_OL2010a,
  author = {Watts, Michael R.},
  journal = {Optics Letters},
  title = {Adiabatic microring resonators},
  year = {2010},
  issn = {0146-9592},
  number = {19},
  pages = {3231},
  volume = {35},
  abstract = {A class of whispering-gallery-mode resonators, herein referred to as adiabatic microring resonators, is proposed and numerically demonstrated. Adiabatic microrings enable electrical and mechanical contact to be made to the resonator without inducing radiation, while supporting only a single radial mode and therein achieving an uncorrupted free spectral range (FSR). Rigorous finite-difference time-domain simulations indicate that adiabatic microrings with outer diameters as small as 4 $\mu$m can achieve resonator quality factors (Qs) as high as Q = 88,000 and an FSR of 8.2 THz, despite large internal contacts.},
  creationdate = {2022-11-17T13:13:02},
  doi = {10.1364/ol.35.003231},
  file = {Adiabatic_microring_resonators_2010_Optics_Letters.pdf:AdiabaticMicroringResonators_OL2010a.pdf:application/pdf},
  groups = {thermo_optic_phase_shifter, wgm_bend, high_efficient_tuning, ring_heater_fsr>3200GHz},
  language = {EN},
  modificationdate = {2022-11-17T15:38:56},
  pmid = {20890343},
  url = {http://www.opticsinfobase.org/viewmedia.cfm?uri=ol-35-19-3231&seq=0&html=true},
  urldate = {2015-04-03},
}

