  language = {EN},
  modificationdate = {2022-11-17T15:38:58},
  shorttitle = {Design of curved waveguides},
  url = {https://www.osapublishing.org/josaa/abstract.cfm?uri=josaa-20-1-130},
  urldate = {2021-03-23},
}

