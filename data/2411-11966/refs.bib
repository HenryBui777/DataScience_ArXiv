@article{Strehl_paper,
  author = {Marcos A. van Dam and David Le Mignant and Bruce A. Macintosh},
  journal = {Appl. Opt.},
  keywords = {Active or adaptive optics; Atmospheric turbulence; Wave-front sensing; Adaptive optics; Atmospheric turbulence; Deformable mirrors; Large telescopes; Near infrared; Wavefront aberrations},
  number = {29},
  pages = {5458--5467},
  publisher = {Optica Publishing Group},
  title = {Performance of the Keck Observatory adaptive-optics system},
  volume = {43},
  month = {Oct},
  year = {2004},
  url = {https://opg.optica.org/ao/abstract.cfm?URI=ao-43-29-5458},
  doi = {10.1364/AO.43.005458},
  abstract = {The adaptive-optics (AO) system at the W. M. Keck Observatory is characterized. We calculate the error budget of the Keck AO system operating in natural guide star mode with a near-infrared imaging camera. The measurement noise and bandwidth errors are obtained by modeling the control loops and recording residual centroids. Results of sky performance tests are presented: The AO system is shown to deliver images with average Strehl ratios of as much as 0.37 at 1.58 $\mu$m when a bright guide star is used and of 0.19 for a magnitude 12 star. The images are consistent with the predicted wave-front error based on our error budget estimates.},
}

