@book{Dexheimer2017,
  title = {Terahertz {Spectroscopy},
  isbn = {978-1-4200-0770-1},
  shorttitle = {Terahertz {Spectroscopy},
  abstract = {The development of new sources and methods in the terahertz spectral range has generated intense interest in terahertz spectroscopy and its application in an array of fields. Presenting state-of-the-art terahertz spectroscopic techniques, Terahertz Spectroscopy: Principles and Applications focuses on time-domain methods based on femtosecond laser sources and important recent applications in physics, materials science, chemistry, and biomedicine. The first section of the book examines instrumentation and methods for terahertz spectroscopy. It provides a comprehensive treatment of time-domain terahertz spectroscopic measurements, including methods for the generation and detection of terahertz radiation, methods for determining optical constants from time-domain measurements, and the use of femtosecond time-resolved techniques. The last two sections explore a variety of applications of terahertz spectroscopy in physics, materials science, chemistry, and biomedicine. With chapters contributed by leading experts in academia, industry, and research, this volume thoroughly discusses methods and applications, setting it apart from other recent books in this emerging terahertz field.},
  publisher = {CRC Press},
  author = {Dexheimer, Susan L.},
  year = {2017},
  keywords = {Science / Chemistry / Analytic, Science / Chemistry / Industrial \& Technical, Science / Life Sciences / General, Science / Physics / Optics \& Light, Technology \& Engineering / Electrical, Technology \& Engineering / Environmental / General, Technology \& Engineering / Lasers \& Photonics},
}

@article{Mittleman2017,
  title = {Perspective: {Terahertz},
  volume = {122},
  issn = {0021-8979},
  shorttitle = {Perspective},
  url = {https://doi.org/10.1063/1.5007683},
  doi = {10.1063/1.5007683},
  abstract = {The field of terahertz science and technology has been an active and thriving research area for several decades. However, the field has recently experienced an inflection point, as several exciting breakthroughs have enabled new opportunities for both fundamental and applied research. These events are reshaping the field, and will impact research directions for years to come. In this Perspective article, I discuss a few important examples: the development of methods to access nonlinear optical effects in the terahertz range; methods to probe nanoscale phenomena; and, the growing likelihood that terahertz technologies will be a critical player in future wireless networks. Here, a few examples of research in each of these areas are discussed, followed by some speculation about where these exciting breakthroughs may lead in the near future.},
  number = {23},
  urldate = {2024-03-27},
  journal = {J. Appl. Phys.},
  author = {Mittleman, Daniel M.},
  year = {2017},
  pages = {230901},
  file = {Full Text PDF:/home/spock/Zotero/storage/7BVHN52V/Mittleman - 2017 - Perspective Terahertz science and technology.pdf:application/pdf;Snapshot:/home/spock/Zotero/storage/RUV2QFHA/Perspective-Terahertz-science-and-technology.html:text/html},
}

