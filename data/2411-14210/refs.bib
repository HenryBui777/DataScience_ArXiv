@article{Wu:24,
  author = {Xingke Wu and Zhiping Wang and Benli Yu},
  doi = {10.1364/JOSAB.510348},
  url = {https://opg.optica.org/josab/abstract.cfm?URI=josab-41-3-768},
  journal = {J. Opt. Soc. Am. B},
  pages = {768--773},
  publisher = {Optica Publishing Group},
  year = {2024},
  abstract = {We propose a scheme to map atoms via the coherence superpositions of orbital angular momentum (OAM) light. The atoms are prepared in the four-level tripod configuration in the presence of a vortex light, which coherently superposes two Laguerre-Gaussian (LG) beam modes with equal but opposite OAM. Because of the spatially dependent atom-field interaction, the information about the position of the atom can be obtained via the absorption measurement of the weak probe field. It is found that the absorption behavior is significantly impacted by the detuning, control field, azimuthal number, and radial number. Most importantly, atomic mapping accuracy can be controlled by properly adjusting the detunings and control field. The coherent interaction of OAM light with atoms constitutes a platform for active mapping of atoms at specific positions in azimuthal space.},
  volume = {41},
  title = {Mapping of atoms via the coherence superpositions of orbital angular momentum light},
  keywords = {Laser cooling; Light beams; Light matter interactions; Optical properties; Orbital angular momentum multiplexing; Tunable diode lasers},
  month = {Mar},
  number = {3},
}

@article{Kotlyar:19,
