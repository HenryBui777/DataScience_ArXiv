@article{ENGEL1991114,
  author = {J. Engel},
  doi = {https://doi.org/10.1016/0370-2693(91)90712-Y},
  url = {https://www.sciencedirect.com/science/article/pii/037026939190712Y},
  issn = {0370-2693},
  journal = {Physics Letters B},
  pages = {114-119},
  year = {1991},
  abstract = {We discuss the scattering of supersymmetric dark matter particles from nuclei at nonzero momentum transfer. After a brief treatment of spin-independent form factors, we carefully formulate the spin-dependent scattering problem. We conclude with a calculation of a spin-dependent cross section in 131Xe; it falls as the momentum transfer increases, but more slowly than the spin-independent cross section.},
  volume = {264},
  title = {Nuclear form factors for the scattering of weakly interacting massive particles},
  number = {1},
}

