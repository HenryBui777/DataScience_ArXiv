@article{Trefethen93,
  author = {Lloyd N. Trefethen and Anne E. Trefethen and Satish C. Reddy and Tobin A. Driscoll},
  url = {http://www.jstor.org/stable/2882016},
  issn = {00368075, 10959203},
  journal = {Science},
  abstract = {Fluid flows that are smooth at low speeds become unstable and then turbulent at higher speeds. This phenomenon has traditionally been investigated by linearizing the equations of flow and testing for unstable eigenvalues of the linearized problem, but the results of such investigations agree poorly in many cases with experiments. Nevertheless, linear effects play a central role in hydrodynamic instability. A reconciliation of these findings with the traditional analysis is presented based on the "pseudospectra" of the linearized problem, which imply that small perturbations to the smooth flow may be amplified by factors on the order of 10$^5$ by a linear mechanism even though all the eigenmodes decay monotonically. The methods suggested here apply also to other problems in the mathematical sciences that involve nonorthogonal eigenfunctions.},
  pages = {578--584},
  publisher = {American Association for the Advancement of Science},
  year = {1993},
  volume = {261},
  title = {Hydrodynamic Stability Without Eigenvalues},
  urldate = {2022-04-21},
  number = {5121},
}

