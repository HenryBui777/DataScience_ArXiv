@inproceedings{crxclassification,
  author = {Zicari, Paolo and Folino, Gianluigi and Guarascio, Massimo and Pontieri, Luigi},
  title = {Discovering accurate deep learning based predictive models for automatic customer support ticket classification},
  year = {2021},
  isbn = {9781450381048},
  publisher = {Association for Computing Machinery},
  address = {New York, NY, USA},
  url = {https://doi.org/10.1145/3412841.3442109},
  doi = {10.1145/3412841.3442109},
  abstract = {Ticket Management Systems are widespread in disparate kinds of companies and organizations, as they represent a fundamental tool for handling customer requests and issues in an efficient and effective manner. In particular, accurately categorizing incoming tickets is a key task in real-life application settings (e.g., helpdesk/CRM systems and bug tracking systems), in order to improve ticket processing efficiency and effectiveness (e.g., in terms of customer satisfaction). In this work, we propose a comprehensive ticket-categorization analysis that relies on inducing and exploiting a heterogeneous ensemble of deep learning architectures, in addition to a range of functionalities for acquiring, integrating and pre-processing ticket-related information coming from different channels (e.g. mail, chat, web form, etc.). Experimental results conducted on the specific application scenario concerning the data of a publicly available ticket-mining dataset have proven the effectiveness of the framework in different ticket categorization tasks.},
  booktitle = {Proceedings of the 36th Annual ACM Symposium on Applied Computing},
  pages = {1098–1101},
  numpages = {4},
  keywords = {automatic customer support, automatic ticket classification and assignment, ensemble of deep neural networks},
  location = {Virtual Event, Republic of Korea},
  series = {SAC '21},
}

