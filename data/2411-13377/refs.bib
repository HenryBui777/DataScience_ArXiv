  author = {Alkida Balliu and Sebastian Brandt and Fabian Kuhn and Dennis Olivetti},
  title = {Distributed Maximal Matching and Maximal Independent Set on Hypergraphs},
  booktitle = {Proceedings of the 2023 Annual ACM-SIAM Symposium on Discrete Algorithms (SODA)},
  chapter = {},
  pages = {2632-2676},
