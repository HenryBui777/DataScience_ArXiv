  title = {The Design, Implementation, and Performance of the {{Atro-H SXS},
  urldate = {2018-04-19},
  keywords = {anticoincidence detector,Astro-H,Hitomi,microcalorimeter,nosource,x-ray calorimeter,x-ray spectroscopy},
