@article{porter16,
  author = {Porter, F. S. and Chiao, M. P. and Eckart, M. E. and Fujimoto, R. and Ishisaki, Y. and Kelley, R. L. and Kilbourne, C. A. and Leutenegger, M. A. and McCammon, D. and Mitsuda, K. and Sawada, M. and Szymkowiak, A. E. and Takei, Y. and Tashiro, M. and Tsujimoto, M. and Watanabe, T. and Yamada, S.},
