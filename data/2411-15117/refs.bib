}

@inproceedings{Horstman:2024aa,
  author = {Katelyn A. Horstman and Jean-Baptiste Ruffio and
                   Jason J. Wang and Chih-Chun Hsu and Ashley Baker and
                   Luke Finnerty and Jerry Xuan and Daniel Echeverri and
                   Dimitri Mawet and Geoffrey A. Blake and
                   Randall Bartos and Charlotte Z. Bond and
                   Benjamin Calvin and Sylvain Cetre and
                   Jacques-Robert Delorme and Greg Doppmann and
                   Michael P. Fitzgerald and Nemanja J. Jovanovic and
                   Ronald Lopez and Emily C. Martin and Evan Morris and
