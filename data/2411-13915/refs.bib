  year = {2017},
  abstract = {The CAST experiment has been searching for axions and axion-like particles for more than 10 years. The continuous improvements in the detector designs have increased the physics reach of the experiment far beyond what was originally conceived. As part of this development, a new detector based on a GridPix readout had been developed in 2014 and was mounted on the CAST experiment during the end of the data taking period of 2014 and the complete period in 2015. We report on the detector design, its advantages and the performance during both periods.},
