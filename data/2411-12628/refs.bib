@article{angelo_1,
  author = {Renato M Angelo and Nicolas Brunner and Sandu Popescu and Anthony J Short and Paul Skrzypczyk},
  title = {Physics within a quantum reference frame},
  journal = {J. Phys. A},
  volume = {44},
  number = {14},
  pages = {145304},
  url = {http://stacks.iop.org/1751-8121/44/i=14/a=145304},
  year = {2011},
  abstract = {We investigate the physics of quantum reference frames. Specifically, we study several simple scenarios involving a small number of quantum particles, whereby we promote one of these particles to the role of a quantum observer and ask what is the description of the rest of the system, as seen by this observer? We highlight the interesting aspects of such questions by presenting a number of apparent paradoxes. By unravelling these paradoxes, we obtain a better understanding of the physics of quantum reference frames.},
}

