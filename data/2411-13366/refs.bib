@article{TANG1982293,
  author = {Ming-Ching Tang and May Hsu and Shiro Kobayashi},
  doi = {https://doi.org/10.1016/0020-7357(82)90007-5},
  url = {https://www.sciencedirect.com/science/article/pii/0020735782900075},
  issn = {0020-7357},
  journal = {International Journal of Machine Tool Design and Research},
  pages = {293-307},
  year = {1982},
  abstract = {The finite-element method for rigid-plastic materials is used for the analysis of nosing of aluminum alloy 2024 tubular preforms with uniform wall thickness at room temperature. The detailed mechanics were obtained by computer simulation and some of the results, such as load-displacement curves, elongation and thickness distributions, were compared with experimental results. Then, assuming that the strain distributions computed by the finite-element method are valid for preforms having nonuniform thicknesses initially, two types of preform shapes were designed to obtain uniform wall thickness after nosing. Experimental results of nosing these preforms showed that the approach to the problem is satisfactory.},
  volume = {22},
  title = {Analysis of shell nosing—Process mechanics and preform design},
  number = {4},
}

@article{FATNASSI1985643,
  author = {A. Fatnassi and Y. Tomita and A. Shindo},
  doi = {https://doi.org/10.1016/0020-7403(85)90046-3},
  url = {https://www.sciencedirect.com/science/article/pii/0020740385900463},
  issn = {0020-7403},
  journal = {International Journal of Mechanical Sciences},
  pages = {643-651},
  year = {1985},
  abstract = {Theoretical investigations have been carried out to predict the non-axisymmetric buckling seen in the throat of circular elastic-plastic tubes subjected to a nosing operation along a frictionless conically shaped die. The buckling points and associated modes are determined by Hill's bifurcation theory in conjunction with a non-axisymmetric buckling mode. The results show that increasing the die semi-angle and the tube thickness or decreasing the material work-hardening rate are always beneficial to improve the buckling limit. The associated critical buckling mode number generally decreases as the tube thickness increases and does not depend drastically on the die semiangle nor on the hardening rate. The effect of the average r value is substantial and the buckling limit is improved when the r value reduces. Part of the present results predict well the results observed in existing experimental work.},
  volume = {27},
  title = {Non-axisymmetric buckling behaviour of elastic-plastic circular tubes subjected to a nosing operation},
  number = {10},
}

@article{HWANG19871,
  author = {S.M. Hwang and S. Kobayashi},
  doi = {https://doi.org/10.1016/S0890-6955(87)80035-4},
  url = {https://www.sciencedirect.com/science/article/pii/S0890695587800354},
  issn = {0890-6955},
  journal = {International Journal of Machine Tools and Manufacture},
  pages = {1-14},
  year = {1987},
  abstract = {The method of backward tracing of deformation processes has been applied successfully to preformdesign in metal forming. In this investigation the method was extended to include the effect of temperature. The basic formulation for the method is presented and the solution scheme is described with the emphasis on the coupled thermoviscoplastic analysis. The method was applied to the problem of preform design in shell nosing at elevated temperatures. It was shown that the precise preform shape and the temperature distributions in the preform were determined simultaneously.},
  volume = {27},
  title = {Preform design in shell nosing at elevated temperatures},
  number = {1},
}

@article{KWAN2003530,
  author = {Chin-Tarn Kwan},
  doi = {https://doi.org/10.1016/S0924-0136(03)00781-7},
  url = {https://www.sciencedirect.com/science/article/pii/S0924013603007817},
  issn = {0924-0136},
