@inproceedings{DMS_double_cone,
  author = {Maninder S. Grover and Paolo Valentini and Nicholas J. Bisek and Ashley M. Verhoff},
  title = {{First principle simulation of CUBRC double cone experiments},
  booktitle = {AIAA Aviation Forum},
  year = {2023},
  chapter = {},
  pages = {},
  doi = {10.2514/6.2023-3735},
  abstract = {View Video Presentation: https://doi.org/10.2514/6.2023-3735.vidIn this work, we conduct an ab initio Direct Molecular Simulation (DMS) of a hypervelocity experiment conducted at the Calspan University of Buffalo Research Center (CUBRC). We simulate Run 88 conducted at CUBRC, which involved a Mach 8.2 oxygen flow over a double cone geometry. This case is rich in flow physics, such as shock-shock and shock-boundary layer interactions. Additionally, the flow conditions cause internal energy excitation and dissociation of molecular oxygen in the system. As DMS only uses first principles-derived potential energy surfaces (PESs) as the sole modeling input for the calculation, all thermophysics, transport, and fluid dynamics phenomena seen in this calculation can be attributed to the ab initio PES. Furthermore, we conduct a comparative analysis between flow properties obtained from the DMS and lower fidelity Direct Simulation Monte Carlo (DSMC) simulations.},
}

