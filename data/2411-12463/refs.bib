@article{Xing2014,
  author = {Xing, Guichuan and Mathews, Nripan and Lim, Swee Sien and Yantara, Natalia and Liu, Xinfeng and Sabba, Dharani and Grätzel, Michael and Mhaisalkar, Subodh and Sum, Tze Chien},
