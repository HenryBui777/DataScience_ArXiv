@article{yasuhirosekinoFastScramblers2008a,
  author = {{Yasuhiro Sekino},
  doi = {10.1088/1126-6708/2008/10/065},
  url = {https://dx.doi.org/10.1088/1126-6708/2008/10/065},
  issn = {1126-6708},
  journal = {Journal of High Energy Physics},
  abstract = {We consider the problem of how fast a quantum system can scramble (thermalize) information, given that the interactions are between bounded clusters of degrees of freedom;  pairwise interactions would be an example. Based on previous work, we conjecture:   
The most rapid scramblers take a time logarithmic in the number of degrees of freedom. Matrix quantum mechanics (systems whose degrees of freedom are n by n matrices) saturate the bound. Black holes are the fastest scramblers in nature.
The conjectures are based on two sources, one from quantum information theory, and the other from the study of black holes in String Theory.},
