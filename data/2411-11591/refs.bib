@article{Kozak2014,
  author = {Kozák, M., Trojánek, F. & Malý, P. Temperature and density dependence of exciton dynamics in IIa diamond: Experimental and theoretical study. Phys. Status Solidi A 211, 2244–2250},
  pages = {2244-2250},
  doi = {https://doi.org/10.1002/pssa.201431174},
  abstract = {We studied dependence of time-resolved and time-integrated photoluminescence of free excitons in IIa type monocrystalline diamond on sample temperature and carrier density. Numerical model based on rate equations for time evolution of excited carrier and occupied traps populations was used for theoretical modelling. The density dependent diffusion and free carrier/free exciton equilibrium were shown to be important factors in exciton recombination dynamics. Room temperature quantum yield of excitonic photoluminescence was found to be strongly dependent on the carrier density with the highest measured value of 13\% at n = 1017 cm−3.},
  year = {2014},
  url = {https://onlinelibrary.wiley.com/doi/abs/10.1002/pssa.201431174},
  volume = {211},
  eprint = {https://onlinelibrary.wiley.com/doi/pdf/10.1002/pssa.201431174},
  title = {Temperature and density dependence of exciton dynamics in IIa diamond: Experimental and theoretical study},
  keywords = {diamond, exciton recombination, optical spectroscopy},
  journal = {physica status solidi (a)},
  number = {10},
}

