@inproceedings{pfeiffer_perception_2017,
  title = {From {Perception},
  shorttitle = {From {Perception},
  url = {http://arxiv.org/abs/1609.07910},
  doi = {10.1109/ICRA.2017.7989182},
  abstract = {Learning from demonstration for motion planning is an ongoing research topic. In this paper we present a model that is able to learn the complex mapping from raw 2D-laser range ﬁndings and a target position to the required steering commands for the robot. To our best knowledge, this work presents the ﬁrst approach that learns a target-oriented endto-end navigation model for a robotic platform. The supervised model training is based on expert demonstrations generated in simulation with an existing motion planner. We demonstrate that the learned navigation model is directly transferable to previously unseen virtual and, more interestingly, real-world environments. It can safely navigate the robot through obstaclecluttered environments to reach the provided targets. We present an extensive qualitative and quantitative evaluation of the neural network-based motion planner, and compare it to a grid-based global approach, both in simulation and in realworld experiments.},
