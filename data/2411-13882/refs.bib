  annote = {Comment: 19 pages, 11 figures},
  file = {arXiv Fulltext PDF:/Users/jesuscifuentes/Zotero/storage/SAMZEVYM/Xue et al. - 2022 - Computing with spin qubits at the surface code err.pdf:application/pdf;arXiv.org Snapshot:/Users/jesuscifuentes/Zotero/storage/ARULYAC5/2107.html:text/html},
