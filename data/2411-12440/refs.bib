@misc{Waczynska2024,
  author = {Waczyńska, Joanna and Borycki, Piotr and Tadeja, Sławomir and Tabor, Jacek and Spurek, Przemysław},
  doi = {10.48550/arxiv.2402.01459},
  primaryclass = {cs.CV},
  eprint = {2402.01459},
  abstract = {Recently, a range of neural network-based methods for image rendering have been introduced. One such widely researched neural radiance field (NeRF) relies on a neural network to represent 3D scenes, allowing for realistic view synthesis from a small number of 2D images. However, most NeRF models are constrained by long training and inference times. In comparison, Gaussian Splatting (GS) is a novel, state-of-the-art technique for rendering points in a 3D scene by approximating their contribution to image pixels through Gaussian distributions, enabling fast training and real-time rendering. A drawback of GS is the absence of a well-defined approach for conditioning, as it involves managing several hundred thousand Gaussian components. To address this, we introduce the Gaussian Mesh Splatting (GaMeS) model, which allows modification of Gaussian components similarly to meshes. Each Gaussian component is parameterized by the vertices of a mesh face. Our model requires either mesh initialization as input or mesh estimation during training. Furthermore, we define Gaussian splats based solely on their location on the mesh, permitting automatic adjustments in position, scale, and rotation during animation. As a result, we achieve real-time rendering of editable GS.},
  year = {2024},
  archiveprefix = {arXiv},
  eprinttype = {arXiv},
  title = {GaMeS: Mesh-Based Adapting and Modification of Gaussian Splatting},
}

@article{Kerbl2023,
  author = {Kerbl, Bernhard and Kopanas, Georgios and Leimk{\"u},
  url = {https://repo-sam.inria.fr/fungraph/3d-gaussian-splatting/},
  journal = {ACM Transactions on Graphics (TOG)},
  abstract = {Radiance field methods have recently revolutionized novel-view synthesis of scenes captured with multiple photos or videos. However, achieving high visual quality still requires neural networks that are costly to train and render, while recent faster methods inevitably trade off speed for quality. For unbounded and complete scenes (rather than isolated objects) and 1080p resolution rendering, no current method can achieve real-time display rates. We introduce three key elements that allow us to achieve state-of-the-art visual quality while maintaining competitive training times and, importantly, allow high-quality real-time (≥ 30 fps) novel-view synthesis at 1080p resolution. First, starting from sparse points produced during camera calibration, we represent the scene with 3D Gaussians that preserve desirable properties of continuous volumetric radiance fields for scene optimization while avoiding unnecessary computation in empty space. Second, we perform interleaved optimization/density control of the 3D Gaussians, notably optimizing anisotropic covariance to achieve an accurate representation of the scene. Third, we develop a fast visibility-aware rendering algorithm that supports anisotropic splatting and both accelerates training and allows real-time rendering. We demonstrate state-of-the-art visual quality and real-time rendering on several established datasets.},
  year = {2023},
  volume = {42},
  title = {3D Gaussian Splatting for Real-Time Radiance Field Rendering},
  month = {July},
  number = {4},
}

@inproceedings{Guedon2024,
  author = {Guédon, Antoine and Lepetit, Vincent},
  year = {2024},
  pages = {5354--5363},
  abstract = {We propose a method to allow precise and extremely fast mesh extraction from 3D Gaussian Splatting. Gaussian Splatting has recently become very popular as it yields realistic rendering while being significantly faster to train than NeRFs. However, it is challenging to extract a mesh from the millions of tiny 3D Gaussians, as these Gaussians tend to be unorganized after optimization, and no method has been proposed so far. Our first key contribution is a regularization term that encourages the Gaussians to align well with the surface of the scene. We then introduce a method that exploits this alignment to extract a mesh from the Gaussians using Poisson reconstruction, which is fast, scalable, and preserves details, in contrast to the Marching Cubes algorithm usually applied to extract meshes from neural SDFs. Finally, we introduce an optional refinement strategy that binds Gaussians to the surface of the mesh and jointly optimizes these Gaussians and the mesh through Gaussian splatting rendering. This enables easy editing, sculpting, animating, and relighting of the Gaussians by manipulating the mesh instead of the Gaussians themselves. Retrieving such an editable mesh for realistic rendering is done within minutes with our method, compared to hours with the state-of-the-art method on SDFs, while providing better rendering quality.},
  booktitle = {Proceedings of the IEEE/CVF Conference on Computer Vision and Pattern Recognition (CVPR)},
  title = {SuGaR: Surface-Aligned Gaussian Splatting for Efficient 3D Mesh Reconstruction and High-Quality Mesh Rendering},
  month = {June},
}

@misc{Gao2024,
  author = {Gao, Lin and Yang, Jie and Zhang, Bo-Tao and Sun, Jia-Mu and Yuan, Yu-Jie and Fu, Hongbo and Lai, Yu-Kun},
  doi = {10.48550/arxiv.2402.04796},
  primaryclass = {cs.GR},
  eprint = {2402.04796},
  abstract = {Neural implicit representations, including Neural Distance Fields and Neural Radiance Fields, have demonstrated significant capabilities for reconstructing surfaces with complicated geometry and topology, and generating novel views of a scene. Nevertheless, it is challenging for users to directly deform or manipulate these implicit representations with large deformations in real-time. Gaussian Splatting (GS) has recently become a promising method with explicit geometry for representing static scenes and facilitating high-quality, real-time synthesis of novel views. However, it cannot be easily deformed due to the use of discrete Gaussians and lack of explicit topology. To address this, we develop a novel GS-based method that enables interactive deformation. Our key idea is to design an innovative mesh-based GS representation, integrated into Gaussian learning and manipulation. 3D Gaussians are defined over an explicit mesh, and they are bound with each other: the rendering of 3D Gaussians guides the mesh face split for adaptive refinement, and the mesh face split directs the splitting of 3D Gaussians. Moreover, the explicit mesh constraints help regularize the Gaussian distribution, suppressing poor-quality Gaussians (e.g., misaligned Gaussians, long-narrow shaped Gaussians), thus enhancing visual quality and avoiding artifacts during deformation. Based on this representation, we further introduce a large-scale Gaussian deformation technique to enable deformable GS, which alters the parameters of 3D Gaussians according to the manipulation of the associated mesh. Our method benefits from existing mesh deformation datasets for more realistic data-driven Gaussian deformation. Extensive experiments show that our approach achieves high-quality reconstruction and effective deformation, while maintaining promising rendering results at a high frame rate (65 FPS on average).},
  year = {2024},
  archiveprefix = {arXiv},
  eprinttype = {arXiv},
  title = {Mesh-Based Gaussian Splatting for Real-Time Large-Scale Deformation},
}

@inproceedings{Yu2024,
  author = {Yu, Zehao and Chen, Anpei and Huang, Binbin and Sattler, Torsten and Geiger, Andreas},
  year = {2024},
  pages = {19447--19456},
  abstract = {Recently, 3D Gaussian Splatting has demonstrated impressive novel view synthesis results, reaching high fidelity and efficiency. However, strong artifacts can be observed when changing the sampling rate, e.g., by changing focal length or camera distance. We find that the source of this phenomenon can be attributed to the lack of 3D frequency constraints and the usage of a 2D dilation filter. To address this problem, we introduce a 3D smoothing filter to constrain the size of the 3D Gaussian primitives based on the maximal sampling frequency induced by the input views. It eliminates high-frequency artifacts when zooming in. Moreover, replacing 2D dilation with a 2D Mip filter, which simulates a 2D box filter, effectively mitigates aliasing and dilation issues. Our evaluation, including scenarios such as training on single-scale images and testing on multiple scales, validates the effectiveness of our approach.},
  booktitle = {Proceedings of the IEEE/CVF Conference on Computer Vision and Pattern Recognition (CVPR)},
  title = {Mip-Splatting: Alias-Free 3D Gaussian Splatting},
  month = {June},
}

@inproceedings{Huang2024,
  author = {Huang, Binbin and Yu, Zehao and Chen, Anpei and Geiger, Andreas and Gao, Shenghua},
  year = {2024},
  abstract = {3D Gaussian Splatting (3DGS) has recently revolutionized radiance field reconstruction, achieving high-quality novel view synthesis and fast rendering speed without baking. However, 3DGS fails to accurately represent surfaces due to the multi-view inconsistent nature of 3D Gaussians. We present 2D Gaussian Splatting (2DGS), a novel approach to model and reconstruct geometrically accurate radiance fields from multi-view images. Our key idea is to collapse the 3D volume into a set of 2D oriented planar Gaussian disks. Unlike 3D Gaussians, 2D Gaussians provide view-consistent geometry while modeling surfaces intrinsically. To accurately recover thin surfaces and achieve stable optimization, we introduce a perspective-correct 2D splatting process utilizing ray-splat intersection and rasterization. Additionally, we incorporate depth distortion and normal consistency terms to further enhance the quality of the reconstructions. We demonstrate that our differentiable renderer allows for noise-free and detailed geometry reconstruction while maintaining competitive appearance quality, fast training speed, and real-time rendering.},
  publisher = {Association for Computing Machinery},
  doi = {10.1145/3641519.3657428},
  booktitle = {SIGGRAPH},
  title = {2D Gaussian Splatting for Geometrically Accurate Radiance Fields},
}

@inproceedings{Ye2024a,
  author = {Ye, Zongxin and Li, Wenyu and Liu, Sidun and Qiao, Peng and Dou, Yong},
  year = {2024},
  abstract = {3D Gaussian Splatting (3D-GS) couples 3D Gaussian primitives with differentiable rasterization to achieve high-quality novel view synthesis while providing advanced real-time rendering performance. However, due to flaws in the adaptive density control strategy of 3D-GS, it frequently suffers from over-reconstruction issues in intricate scenes with high-frequency details, resulting in blurry rendered images. The underlying reason for this flaw has yet to be fully explored. In this work, we present a comprehensive analysis of the cause of these artifacts, namely gradient collision, which prevents large Gaussians in over-reconstructed regions from splitting. To address this issue, we propose a novel homodirectional view-space positional gradient as the criterion for densification. Our strategy efficiently identifies large Gaussians in over-reconstructed regions and recovers fine details by splitting. We evaluate our method on various challenging datasets. Experimental results indicate that our approach achieves the best rendering quality with reduced or similar memory consumption. Our method is easy to implement and can be incorporated into many recent Gaussian Splatting-based methods. We will open source our codes upon formal publication. Our project page is available at: this https URL.},
  url = {https://openreview.net/forum?id=tuch82hlmx},
  booktitle = {ACM Multimedia 2024},
  title = {AbsGS: Recovering Fine Details in 3D Gaussian Splatting},
}

@inproceedings{Lu2024,
  author = {Lu, Tao and Yu, Mulin and Xu, Linning and Xiangli, Yuanbo and Wang, Limin and Lin, Dahua and Dai, Bo},
  year = {2024},
  pages = {20654--20664},
  abstract = {Neural rendering methods have significantly advanced photo-realistic 3D scene rendering in various academic and industrial applications. The recent 3D Gaussian Splatting method has achieved state-of-the-art rendering quality and speed by combining the benefits of both primitive-based and volumetric representations. However, it often results in heavily redundant Gaussians that try to fit every training view, neglecting the underlying scene geometry. Consequently, the model becomes less robust to significant view changes, texture-less areas, and lighting effects. We introduce Scaffold-GS, which uses anchor points to distribute local 3D Gaussians and predicts their attributes on-the-fly based on viewing direction and distance within the view frustum. Anchor growing and pruning strategies are developed based on the importance of neural Gaussians to reliably improve scene coverage. Our method effectively reduces redundant Gaussians while delivering high-quality rendering and demonstrates enhanced capability to handle scenes with varying levels of detail and view-dependent observations without sacrificing rendering speed. Project page: https://city-super.github.io/scaffold-gs.},
  booktitle = {Proceedings of the IEEE/CVF Conference on Computer Vision and Pattern Recognition (CVPR)},
  title = {Scaffold-GS: Structured 3D Gaussians for View-Adaptive Rendering},
  month = {June},
}

@article{Lee2024,
  author = {Lee, Byeonghyeon and Lee, Howoong and Sun, Xiangyu and Ali, Usman and Park, Eunbyung},
  year = {2024},
  abstract = {Recent studies in Radiance Fields have paved the way for novel view synthesis with photorealistic rendering quality. However, they typically employ neural networks and volumetric rendering, which are costly to train and hinder their use in various real-time applications due to lengthy rendering times. Recently, 3D Gaussian splatting-based approaches have been proposed to model 3D scenes, achieving remarkable visual quality while rendering images in real-time. However, these methods suffer from severe degradation in rendering quality when the training images are blurry. Blurriness commonly arises from lens defocusing, object motion, and camera shake, interfering with the acquisition of clean images. Several prior studies have attempted to render sharp images from blurry inputs using neural fields. However, most of these works are tailored for volumetric rendering-based neural radiance fields and are not directly applicable to rasterization-based 3D Gaussian splatting methods. In response, we propose a novel real-time deblurring framework, Deblurring 3D Gaussian Splatting, using a small Multi-Layer Perceptron (MLP) that manipulates the covariance of each 3D Gaussian to model scene blurriness. Our method retains real-time rendering capability while reconstructing fine and sharp details from blurry images. Extensive experiments on benchmark datasets demonstrate the effectiveness of our approach for deblurring.},
  title = {Deblurring 3D Gaussian Splatting},
  journal = {arXiv preprint arXiv:2401.00834},
}

@article{Ververas2024,
  author = {Ververas, Evangelos and Potamias, Rolandos Alexandros and Song, Jifei and Deng, Jiankang and Zafeiriou, Stefanos},
  year = {2024},
  abstract = {Following the advent of NeRFs, 3D Gaussian Splatting (3D-GS) has paved the way for real-time neural rendering by overcoming the computational burden of volumetric methods. Building on the pioneering work of 3D-GS, several methods have attempted to achieve compressible and high-fidelity performance alternatives. However, by employing a geometry-agnostic optimization scheme, these methods neglect the inherent 3D structure of the scene, thereby limiting the expressivity and quality of the representation, resulting in floating points and artifacts. In this work, we propose a structure-aware Gaussian Splatting method (SAGS) that implicitly encodes the geometry of the scene, leading to state-of-the-art rendering performance and reduced storage requirements on benchmark novel-view synthesis datasets. SAGS is based on a local-global graph representation that facilitates learning of complex scenes and enforces meaningful point displacements to preserve scene geometry. Additionally, we introduce a lightweight version of SAGS using a simple yet effective mid-point interpolation scheme, providing a compact representation of the scene with up to 24x size reduction without relying on any compression strategies. Extensive experiments across multiple benchmark datasets demonstrate the superiority of SAGS over state-of-the-art 3D-GS methods in both rendering quality and model size. Furthermore, our structure-aware method effectively mitigates floating artifacts and irregular distortions seen in previous methods while obtaining precise depth maps. Project page: https://eververas.github.io/SAGS/.},
  title = {SAGS: Structure-Aware 3D Gaussian Splatting},
  journal = {arXiv preprint arXiv:2404.19149},
}

@article{Zhao2024,
  author = {Zhao, Lingzhe and Wang, Peng and Liu, Peidong},
  year = {2024},
  abstract = {While neural rendering has demonstrated impressive capabilities in 3D scene reconstruction and novel view synthesis, it heavily relies on high-quality sharp images and accurate camera poses. Numerous approaches have been proposed to train Neural Radiance Fields (NeRF) with motion-blurred images, commonly encountered in real-world scenarios such as low-light or long-exposure conditions. However, the implicit representation of NeRF struggles to accurately recover intricate details from severely motion-blurred images and cannot achieve real-time rendering. In contrast, recent advancements in 3D Gaussian Splatting achieve high-quality 3D scene reconstruction and real-time rendering by explicitly optimizing point clouds as Gaussian spheres. In this paper, we introduce a novel approach, named BAD-Gaussians (Bundle Adjusted Deblur Gaussian Splatting), which leverages explicit Gaussian representation and handles severe motion-blurred images with inaccurate camera poses to achieve high-quality scene reconstruction. Our method models the physical image formation process of motion-blurred images and jointly learns the parameters of Gaussians while recovering camera motion trajectories during exposure time. In our experiments, we demonstrate that BAD-Gaussians not only achieves superior rendering quality compared to previous state-of-the-art deblur neural rendering methods on both synthetic and real datasets but also enables real-time rendering capabilities.},
  title = {BAD-Gaussians: Bundle Adjusted Deblur Gaussian Splatting},
  journal = {arXiv preprint arXiv:2403.11831},
}

@article{Peng2024,
  author = {Peng, Cheng and Tang, Yutao and Zhou, Yifan and Wang, Nengyu and Liu, Xijun and Li, Deming and Chellappa, Rama},
  year = {2024},
  abstract = {Recent efforts in using 3D Gaussians for scene reconstruction and novel view synthesis can achieve impressive results on curated benchmarks; however, images captured in real life are often blurry. In this work, we analyze the robustness of Gaussian-Splatting-based methods against various image blur, such as motion blur, defocus blur, downscaling blur, etc. Under these degradations, Gaussian-Splatting-based methods tend to overfit and produce worse results than Neural-Radiance-Field-based methods. To address this issue, we propose Blur Agnostic Gaussian Splatting (BAGS). BAGS introduces additional 2D modeling capacities such that a 3D-consistent and high-quality scene can be reconstructed despite image-wise blur. Specifically, we model blur by estimating per-pixel convolution kernels from a Blur Proposal Network (BPN). BPN is designed to consider spatial, color, and depth variations of the scene to maximize modeling capacity. Additionally, BPN also proposes a quality-assessing mask, which indicates regions where blur occurs. Finally, we introduce a coarse-to-fine kernel optimization scheme that avoids sub-optimal solutions due to sparse point cloud initialization. We demonstrate that BAGS achieves photorealistic renderings under various challenging blur conditions, significantly improving upon existing approaches.},
  title = {BAGS: Blur Agnostic Gaussian Splatting through Multi-Scale Kernel Modeling},
  journal = {arXiv preprint arXiv:2403.04926},
}

@article{Seiskari2024,
  author = {Seiskari, Otto and Ylilammi, Jerry and Kaatrasalo, Valtteri and Rantalankila, Pekka and Turkulainen, Matias and Kannala, Juho and Rahtu, Esa and Solin, Arno},
  year = {2024},
  abstract = {High-quality scene reconstruction and novel view synthesis based on Gaussian Splatting (3DGS) typically require steady, high-quality photographs, often impractical to capture with handheld cameras. We present a method that adapts to camera motion and allows high-quality scene reconstruction with handheld video data suffering from motion blur and rolling shutter distortion. Our approach utilizes velocities estimated using visual-inertial odometry (VIO) and models non-static camera poses during exposure. We formulate a differentiable rendering pipeline that incorporates rolling-shutter and motion blur effects into the 3DGS framework. Our results on synthetic and real data demonstrate superior performance in mitigating camera motion over existing methods, advancing 3DGS in naturalistic settings.},
  title = {Gaussian Splatting on the Move: Blur and Rolling Shutter Compensation for Natural Camera Motion},
  journal = {arXiv preprint arXiv:2403.13327},
}

@misc{Zhang2024,
  author = {Zhang, Zheng and Hu, Wenbo and Lao, Yixing and He, Tong and Zhao, Hengshuang},
  doi = {10.48550/arxiv.2403.15530},
  primaryclass = {cs.CV},
  eprint = {2403.15530},
  abstract = {3D Gaussian Splatting (3DGS) has demonstrated impressive novel view synthesis results while advancing real-time rendering performance. However, it relies heavily on the quality of the initial point cloud, leading to artifacts in areas with insufficient initializing points. We propose Pixel-GS, a novel method that incorporates pixel coverage into the growth condition of 3D Gaussians. This dynamic approach ensures better point cloud growth, reducing artifacts and improving reconstruction. Additionally, we introduce a gradient scaling strategy based on distance to suppress floaters near the camera. Extensive experiments demonstrate state-of-the-art rendering quality on challenging datasets.},
  year = {2024},
  archiveprefix = {arXiv},
  eprinttype = {arxiv},
  title = {Pixel-GS: Density Control with Pixel-Aware Gradient for 3D Gaussian Splatting},
}

@inproceedings{Yan2024,
  author = {Yan, Zhiwen and Low, Weng Fei and Chen, Yu and Lee, Gim Hee},
  year = {2024},
  pages = {20923--20931},
  abstract = {3D Gaussians have recently emerged as an efficient representation for 3D reconstruction and rendering. However, rendering quality and speed deteriorate drastically at lower resolutions or distant camera positions due to aliasing and slow alpha blending. We propose a multi-scale 3D Gaussian splatting algorithm that maintains Gaussians at different scales to represent the same scene. High-resolution images are rendered with smaller Gaussians, while lower-resolution images use larger Gaussians. Our method achieves 13%--66% PSNR and 160%--2400% rendering speed improvements at 4x--128x scale on the Mip-NeRF360 dataset compared to single-scale splatting.},
  booktitle = {Proceedings of the IEEE/CVF Conference on Computer Vision and Pattern Recognition (CVPR)},
  title = {Multi-Scale 3D Gaussian Splatting for Anti-Aliased Rendering},
  month = {June},
}

@inproceedings{Jiang2024,
  author = {Jiang, Yuheng and Shen, Zhehao and Wang, Penghao and Su, Zhuo and Hong, Yu and Zhang, Yingliang and Yu, Jingyi and Xu, Lan},
  year = {2024},
  pages = {19734--19745},
  abstract = {We have recently seen tremendous progress in photo-real human modeling and rendering. However, efficiently rendering realistic human performance and integrating it into the rasterization pipeline remains challenging. We present HiFi4G, an explicit and compact Gaussian-based approach for high-fidelity human performance rendering from dense footage. Our method marries 3D Gaussian representation with non-rigid tracking, achieving a compact, compression-friendly representation. We propose a dual-graph mechanism to obtain motion priors with a coarse deformation graph for initialization and a fine-grained Gaussian graph to enforce constraints. Using a 4D Gaussian optimization scheme with adaptive spatial-temporal regularizers, we balance the non-rigid prior with Gaussian updates. Our compression scheme with residual compensation enables immersive experiences, achieving a 25× compression rate with less than 2MB of storage per frame. Extensive experiments show that our approach outperforms existing methods in optimization speed, rendering quality, and storage efficiency.},
  booktitle = {Proceedings of the IEEE/CVF Conference on Computer Vision and Pattern Recognition (CVPR)},
  title = {HiFi4G: High-Fidelity Human Performance Rendering via Compact Gaussian Splatting},
  month = {June},
}

@inproceedings{Xiang2024,
  author = {Xiang, Jun and Gao, Xuan and Guo, Yudong and Zhang, Juyong},
  year = {2024},
  pages = {1802--1812},
  abstract = {We propose FlashAvatar, a lightweight 3D animatable avatar representation that reconstructs a digital avatar from a short monocular video in minutes and renders photo-realistic images at 300 FPS on a consumer-grade GPU. Our method embeds a uniform 3D Gaussian field on the surface of a parametric face model and learns spatial offsets for non-surface regions and fine details. Proper initialization reduces the number of Gaussians, enabling fast rendering. Extensive experiments demonstrate that FlashAvatar outperforms existing methods in visual quality and detail preservation while achieving significantly faster rendering. Project page: https://ustc3dv.github.io/FlashAvatar/.},
  booktitle = {Proceedings of the IEEE/CVF Conference on Computer Vision and Pattern Recognition (CVPR)},
  title = {FlashAvatar: High-Fidelity Head Avatar with Efficient Gaussian Embedding},
  month = {June},
}

@article{Chen2024a,
  author = {Chen, Guikun and Wang, Wenguan},
  year = {2024},
  abstract = {3D Gaussian Splatting (GS) has emerged as a transformative technique in explicit radiance field representation. GS departs from neural radiance fields by employing millions of learnable 3D Gaussians and a differentiable rendering algorithm, enabling real-time rendering with unprecedented editability. This survey offers a comprehensive overview of recent developments in GS, covering its principles, applications, and performance on benchmark tasks. We also explore its potential in virtual reality, robotics, and other fields, while identifying challenges and future research directions to foster further advancement in 3D reconstruction and rendering.},
  title = {A Survey on 3D Gaussian Splatting},
  journal = {arXiv preprint arXiv:2401.03890},
}

@article{Fei2024,
  author = {Fei, Ben and Xu, Jingyi and Zhang, Rui and Zhou, Qingyuan and Yang, Weidong and He, Ying},
  year = {2024},
  abstract = {3D Gaussian Splatting (3D-GS) offers explicit scene representation and novel view synthesis without relying on neural networks like Neural Radiance Fields (NeRF). It finds applications in robotics, urban mapping, and virtual reality. This survey organizes recent research into taxonomies based on characteristics and applications, providing an introduction to the theoretical foundations of 3D-GS. We aim to familiarize new researchers with 3D-GS, offer a reference for seminal works, and inspire future research directions.},
  title = {3D Gaussian as a New Vision Era: A Survey},
  journal = {arXiv preprint arXiv:2402.07181},
}

@article{Wu2024,
  author = {Wu, Tong and Yuan, Yu-Jie and Zhang, Ling-Xiao and Yang, Jie and Cao, Yan-Pei and Yan, Ling-Qi and Gao, Lin},
  journal = {Computational Visual Media},
  pages = {613--642},
  year = {2024},
  abstract = {The emergence of 3D Gaussian Splatting (3DGS) has greatly accelerated rendering in novel view synthesis. Unlike implicit representations like neural radiance fields (NeRFs), 3DGS models the scene using Gaussian ellipsoids, enabling efficient rendering via rasterization. Apart from fast rendering, it facilitates tasks like dynamic reconstruction, geometry editing, and physical simulation. This survey provides an overview of recent advancements, classifying methods into categories such as 3D reconstruction, editing, and other applications. Traditional point-based methods and the rendering formulation of 3DGS are also discussed. We aim to assist beginners and experienced researchers in understanding and advancing 3DGS.},
  publisher = {Springer},
  volume = {10},
  title = {Recent Advances in 3D Gaussian Splatting},
  number = {4},
}

@article{Dalal2024,
  author = {Dalal, Anurag and Hagen, Daniel and Robbersmyr, Kjell G. and Knausgård, Kristian Muri},
  year = {2024},
  abstract = {Image-based 3D reconstruction involves inferring the 3D shape of objects from input images. This review focuses on state-of-the-art 3D reconstruction techniques, including novel view synthesis using Gaussian Splatting. We cover input types, model structures, and training strategies, as well as unresolved challenges and future directions. Given rapid developments in this domain, this paper offers a comprehensive overview of the latest advancements in Gaussian Splatting and highlights key research opportunities.},
  publisher = {IEEE},
  title = {Gaussian Splatting: 3D Reconstruction and Novel View Synthesis, a Review},
  journal = {IEEE Access},
}

@inproceedings{Zhou2024,
  author = {Zhou, Xiaoyu and Lin, Zhiwei and Shan, Xiaojun and Wang, Yongtao and Sun, Deqing and Yang, Ming-Hsuan},
  year = {2024},
  pages = {21634--21643},
  abstract = {We present DrivingGaussian, a framework for dynamic autonomous driving scenes. It incrementally models static backgrounds with 3D Gaussians and uses a composite dynamic Gaussian graph to handle multiple moving objects. LiDAR priors are leveraged to improve reconstruction detail and maintain panoramic consistency. Our approach outperforms existing methods in dynamic driving scene reconstruction and enables photorealistic surround-view synthesis. Project page: https://github.com/VDIGPKU/DrivingGaussian.},
  booktitle = {Proceedings of the IEEE/CVF Conference on Computer Vision and Pattern Recognition (CVPR)},
  title = {DrivingGaussian: Composite Gaussian Splatting for Surrounding Dynamic Autonomous Driving Scenes},
}

@inproceedings{Matsuki2024,
  author = {Matsuki, Hidenobu and Murai, Riku and Kelly, Paul H.J. and Davison, Andrew J.},
  year = {2024},
  pages = {18039--18048},
  abstract = {We present the first application of 3D Gaussian Splatting in monocular SLAM. Our method, running at 3 fps, uses Gaussians as the sole 3D representation, enabling accurate tracking, mapping, and high-quality rendering. We introduce geometric verification and regularization to handle ambiguities in dense 3D reconstruction. Our SLAM system achieves state-of-the-art results in novel view synthesis, trajectory estimation, and reconstruction of small and transparent objects.},
  booktitle = {Proceedings of the IEEE/CVF Conference on Computer Vision and Pattern Recognition (CVPR)},
  title = {Gaussian Splatting SLAM},
  month = {June},
}

@inproceedings{Yan2024a,
  author = {Yan, Chi and Qu, Delin and Xu, Dan and Zhao, Bin and Wang, Zhigang and Wang, Dong and Li, Xuelong},
  year = {2024},
  pages = {19595--19604},
  abstract = {We introduce GS-SLAM, the first SLAM system utilizing 3D Gaussian representation. GS-SLAM balances efficiency and accuracy, leveraging real-time differentiable splatting for faster map optimization and rendering. An adaptive expansion strategy adds new or removes noisy Gaussians, enhancing scene geometry reconstruction. A coarse-to-fine technique selects reliable Gaussians to optimize camera pose, achieving competitive results on Replica and TUM-RGBD datasets. Project page: https://gs-slam.github.io/.},
  booktitle = {Proceedings of the IEEE/CVF Conference on Computer Vision and Pattern Recognition (CVPR)},
  title = {GS-SLAM: Dense Visual SLAM with 3D Gaussian Splatting},
  month = {June},
}

@inproceedings{Keetha2024,
  author = {Keetha, Nikhil and Karhade, Jay and Jatavallabhula, Krishna Murthy and Yang, Gengshan and Scherer, Sebastian and Ramanan, Deva and Luiten, Jonathon},
  year = {2024},
  pages = {21357--21366},
  abstract = {SplaTAM introduces explicit 3D Gaussian representations for dense RGB-D SLAM. It utilizes a silhouette mask to capture scene density and an online tracking system tailored for Gaussian-based representations. SplaTAM achieves faster rendering and optimization, improves camera pose estimation, and facilitates structured map expansion. Experiments show up to 2x performance improvements over existing methods in reconstruction and novel-view synthesis.},
  booktitle = {Proceedings of the IEEE/CVF Conference on Computer Vision and Pattern Recognition (CVPR)},
  title = {SplaTAM: Splat Track \& Map 3D Gaussians for Dense RGB-D SLAM},
  month = {June},
}

@inproceedings{Huang2024a,
  author = {Huang, Huajian and Li, Longwei and Cheng, Hui and Yeung, Sai-Kit},
  year = {2024},
  pages = {21584--21593},
  abstract = {We present Photo-SLAM, a novel SLAM framework that combines explicit geometric features for localization with implicit photometric features for texture mapping. A Gaussian-pyramid-based method progressively learns multi-level features, enhancing mapping performance. Extensive experiments with monocular, stereo, and RGB-D datasets demonstrate that Photo-SLAM achieves a 30% PSNR improvement and significantly faster rendering compared to existing systems. The system runs in real time on Jetson AGX Orin, making it suitable for robotics applications. Project page: https://huajianup.github.io/research/Photo-SLAM/.},
  booktitle = {Proceedings of the IEEE/CVF Conference on Computer Vision and Pattern Recognition (CVPR)},
  title = {Photo-SLAM: Real-Time Simultaneous Localization and Photorealistic Mapping for Monocular, Stereo, and RGB-D Cameras},
  month = {June},
}

@article{Mildenhall2021,
  author = {Mildenhall, Ben and Srinivasan, Pratul P. and Tancik, Matthew and Barron, Jonathan T. and Ramamoorthi, Ravi and Ng, Ren},
  year = {2021},
  abstract = {NeRF achieves state-of-the-art results for novel view synthesis by optimizing a continuous volumetric scene function using a sparse set of input views. It represents scenes with a deep network that takes 5D coordinates (spatial location and viewing direction) as input, and outputs volume density and view-dependent radiance. Classic volume rendering projects the output into an image, enabling photorealistic novel views. NeRF outperforms prior work in neural rendering and view synthesis.},
  title = {NeRF: Representing Scenes as Neural Radiance Fields for View Synthesis},
  journal = {Commun. ACM},
}

@inproceedings{Barron2022,
  author = {Barron, Jonathan T. and Mildenhall, Ben and Verbin, Dor and Srinivasan, Pratul P. and Hedman, Peter},
  year = {2022},
  pages = {5470--5479},
  abstract = {Mip-NeRF 360 addresses the challenges of unbounded scenes in neural radiance fields by introducing non-linear scene parameterization, online distillation, and a novel distortion-based regularizer. It achieves 57% lower mean-squared error compared to mip-NeRF and produces high-quality synthesized views and depth maps for complex real-world scenes.},
  booktitle = {Proceedings of the IEEE/CVF Conference on Computer Vision and Pattern Recognition (CVPR)},
  title = {Mip-NeRF 360: Unbounded Anti-Aliased Neural Radiance Fields},
  month = {June},
}

@article{Penner2017,
  author = {Penner, Eric and Zhang, Li},
  doi = {10.1145/3130800.3130855},
  issn = {0730-0301},
  issue_date = {December 2017},
  journal = {ACM Transactions on Graphics (TOG)},
  articleno = {235},
  pages = {235:1--235:11},
  year = {2017},
  abstract = {We present a novel algorithm for view synthesis utilizing soft 3D reconstruction to improve quality, continuity, and robustness. Our representation preserves depth uncertainty throughout 3D reconstruction and rendering, providing continuity across views and robustness to depth uncertainty. The algorithm applies efficient O(1) filters and works with structured or unstructured input views. We compare our method with classical and learning-based algorithms on lightfields, wide-baseline captures, and videos from camera arrays.},
  address = {New York, NY, USA},
  publisher = {Association for Computing Machinery},
  volume = {36},
  title = {Soft 3D Reconstruction for View Synthesis},
  keywords = {3D reconstruction, view synthesis},
  month = {November},
  number = {6},
}

@inproceedings{Henzler2019,
  author = {Henzler, Philipp and Mitra, Niloy J. and Ritschel, Tobias},
  year = {2019},
  abstract = {We introduce PlatonicGAN, a method to discover 3D structure from unstructured 2D images. The key idea is to generate 3D shapes that, when rendered, are indistinguishable from ground truth images under various poses. This approach leverages adversarial rendering to tap into unstructured 2D image collections, eliminating the need for annotated 3D datasets. Our framework introduces differentiable rendering layers, such as visual hull and emission-absorption, and achieves consistent improvements over baseline methods in reconstructing 3D shapes from unstructured data.},
  booktitle = {Proceedings of the IEEE/CVF International Conference on Computer Vision (ICCV)},
  title = {Escaping Plato's Cave: 3D Shape from Adversarial Rendering},
  month = {October},
}

@inproceedings{Sitzmann2019,
  author = {Sitzmann, Vincent and Thies, Justus and Heide, Felix and Niessner, Matthias and Wetzstein, Gordon and Zollhöfer, Michael},
  year = {2019},
  abstract = {We propose DeepVoxels, a persistent 3D feature embedding for view synthesis that encodes view-dependent appearance without explicit geometry modeling. Our approach utilizes a Cartesian 3D grid of embedded features to represent scene structure and combines insights from 3D computer vision and adversarial learning. DeepVoxels demonstrates high-quality novel view synthesis for complex scenes and enforces perspective and multi-view geometry through a re-rendering loss.},
  booktitle = {Proceedings of the IEEE/CVF Conference on Computer Vision and Pattern Recognition (CVPR)},
  title = {DeepVoxels: Learning Persistent 3D Feature Embeddings},
  month = {June},
}

@article{Mueller2022,
  author = {M{\"u},
  doi = {10.1145/3528223.3530127},
  issn = {0730-0301},
  journal = {ACM Transactions on Graphics (TOG)},
  articleno = {102},
  abstract = {We propose a multiresolution hash encoding to reduce the computational cost of neural graphics primitives. Our method augments a small neural network with a hash table of trainable feature vectors optimized using stochastic gradient descent. This architecture disambiguates hash collisions and enables efficient parallelism on modern GPUs. Implemented with fused CUDA kernels, our approach achieves orders-of-magnitude speedups, enabling high-quality neural graphics primitive training within seconds and rendering in milliseconds at 1080p resolution.},
  year = {2022},
  address = {New York, NY, USA},
  publisher = {Association for Computing Machinery},
  numpages = {15},
  volume = {41},
  title = {Instant Neural Graphics Primitives with a Multiresolution Hash Encoding},
  keywords = {GPUs, encodings, function approximation, hashing, image synthesis, neural networks, parallel computation},
  month = {July},
  number = {4},
}

@inproceedings{Lassner2021,
  author = {Lassner, Christoph and Zollhöfer, Michael},
  year = {2021},
  pages = {1440--1449},
  abstract = {We introduce Pulsar, a sphere-based differentiable rendering module that is fast, modular, and easy to integrate with PyTorch. Pulsar addresses challenges in neural rendering, such as topological inconsistencies and high memory consumption, by using spheres for scene representation. This design allows for real-time rendering and optimization of millions of spheres. Pulsar achieves unprecedented rendering speeds and enables applications in 3D reconstruction and neural rendering.},
  booktitle = {Proceedings of the IEEE/CVF Conference on Computer Vision and Pattern Recognition (CVPR)},
  title = {Pulsar: Efficient Sphere-Based Neural Rendering},
  month = {June},
}

@inproceedings{FridovichKeil2022,
  author = {Fridovich-Keil, Sara and Yu, Alex and Tancik, Matthew and Chen, Qinhong and Recht, Benjamin and Kanazawa, Angjoo},
  year = {2022},
  pages = {5501--5510},
  abstract = {We introduce Plenoxels (plenoptic voxels), a system for photorealistic view synthesis. Plenoxels represent a scene as a sparse 3D grid with spherical harmonics, optimized directly from calibrated images via gradient methods and regularization without neural networks. Plenoxels achieve two orders of magnitude faster optimization than Neural Radiance Fields with comparable visual quality. For video and code, see https://alexyu.net/plenoxels.},
  booktitle = {Proceedings of the IEEE/CVF Conference on Computer Vision and Pattern Recognition (CVPR)},
  title = {Plenoxels: Radiance Fields Without Neural Networks},
  month = {June},
}

@article{Kopanas2022,
  author = {Kopanas, Georgios and Leimk{\"u},
  doi = {10.1145/3550454.3555497},
  journal = {ACM Transactions on Graphics (TOG)},
  articleno = {201},
  pages = {201:1--201:15},
  year = {2022},
  abstract = {We introduce a novel point-based representation for computing Neural Point Catacaustics, allowing novel-view synthesis of scenes with curved reflectors. A neural warp field models the catacaustic trajectories of reflections, enabling efficient rendering via point splatting combined with a neural renderer. We explicitly represent reflections with a reflection point cloud, which is displaced by the neural warp field, while a primary point cloud represents the rest of the scene. Our approach supports reflection editing, tracking, cloning, and stereo viewing. Project page: https://repo-sam.inria.fr/fungraph/neural_catacaustics/.},
  address = {New York, NY, USA},
  publisher = {Association for Computing Machinery},
  volume = {41},
  title = {Neural Point Catacaustics for Novel-View Synthesis of Reflections},
  keywords = {catacaustics, differentiable rasterization, neural rendering, point-based rendering, reflections},
  month = {November},
  number = {6},
}

@inproceedings{Xu2022,
  author = {Xu, Qiangeng and Xu, Zexiang and Philip, Julien and Bi, Sai and Shu, Zhixin and Sunkavalli, Kalyan and Neumann, Ulrich},
  year = {2022},
  pages = {5438--5448},
  abstract = {We introduce Point-NeRF, a point-based neural radiance field method that combines the strengths of volumetric neural rendering and multi-view stereo techniques. Point-NeRF models scenes with neural point clouds, associating each point with neural features to represent a radiance field. This approach enables efficient rendering through feature aggregation near scene surfaces using a ray marching-based pipeline. Point-NeRF can be initialized with a pre-trained deep network and fine-tuned to exceed NeRF's visual quality with 30x faster training. Additionally, it includes a novel pruning and growing mechanism to handle errors from 3D reconstruction methods.},
  booktitle = {Proceedings of the IEEE/CVF Conference on Computer Vision and Pattern Recognition (CVPR)},
  title = {Point-NeRF: Point-Based Neural Radiance Fields},
  month = {June},
}

