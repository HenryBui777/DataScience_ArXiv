  shortjournal = {Information and Software Technology},
  author = {Mao, Chengying and Chen, Jifu and Yi, Xiaorong and Wen, Linlin},
  urldate = {2024-03-20},
  date = {2024-05-01},
  keywords = {Metamorphic testing, Metamorphic relation, Recommender system, Reliability, Test oracle problem},
  file = {Mao et al. - 2024 - An empirical study on metamorphic testing for reco.pdf:/Users/madhurimakhirbat/Zotero/storage/JUJDUP9M/Mao et al. - 2024 - An empirical study on metamorphic testing for reco.pdf:application/pdf},
}

