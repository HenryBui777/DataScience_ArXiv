@article{Rothermel1997,
  abstract = {AbstractObservational and model resolution limitations currently preclude analysis of the smallest scales important to numerical prediction of convective storms. These missing scales can be recovered if the forecast model is integrated on a sufficiently fine grid, but not before errors are introduced that subsequently grow in scale and magnitude. This study is the first to systematically evaluate the impact of these initial-condition (IC) resolution errors on high-resolution forecasts of organized convection. This is done by comparing high-resolution supercell simulations generated using identical model settings but successively coarsened ICs. Consistent with the Warn-on-Forecast paradigm, the simulations are initialized with ongoing storms and integrated for 2 h. Both idealized and full-physics experiments are performed in order to examine how more realistic model settings modulate the error evolution.In all experiments, scales removed from the IC (wavelengths {\textless},
  author = {Potvin, Corey K. and Murillo, Elisa M. and Flora, Montgomery L. and Wheatley, Dustan M.},
  doi = {10.1175/JAS-D-16-0098.1},
  file = {:Users/jweyn/Library/Application Support/Mendeley Desktop/Downloaded/Potvin et al. - 2017 - Sensitivity of Supercell Simulations to Initial-Condition Resolution.pdf:pdf},
  issn = {0022-4928},
  journal = {J. Atmos. Sci.},
  keywords = {Cloud resolving models,Data assimilation,Numerical weather prediction/forecasting,Supercells,Tornadoes},
  month = {jan},
  number = {1},
  pages = {5--26},
  title = {{Sensitivity of Supercell Simulations to Initial-Condition Resolution},
  volume = {74},
  year = {2017},
}

