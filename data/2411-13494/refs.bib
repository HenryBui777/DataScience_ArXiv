@article{AFFLECK1985361,
  title = {A new mechanism for baryogenesis},
  journal = {Nuclear Physics B},
  volume = {249},
  number = {2},
  pages = {361-380},
  year = {1985},
  issn = {0550-3213},
  doi = {https://doi.org/10.1016/0550-3213(85)90021-5},
