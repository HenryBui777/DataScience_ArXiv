  doi = {10.1109/ICCWAMTIP60502.2023.10387063},
  url = {https://ieeexplore.ieee.org/document/10387063/},
  copyright = {https://doi.org/10.15223/policy-029},
  annote = {[TLDR] An innovative model for community discovery based on knowledge distillation is introduced to extract information on community structures from intricate networks and apply it to a student model, thus improving the effectiveness of community detection tasks.},
