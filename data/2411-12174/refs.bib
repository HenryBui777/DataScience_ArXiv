  file = {Preprint PDF:C\:\\Users\\Rahul\\Zotero\\storage\\3YRJ6JZZ\\Kiela et al. - 2020 - Supervised Multimodal Bitransformers for Classifyi.pdf:application/pdf;Snapshot:C\:\\Users\\Rahul\\Zotero\\storage\\5TIZQVC7\\1909.html:text/html},
