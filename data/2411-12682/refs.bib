@article{WANG2020104607,
  author = {Zhaojian Wang and Feng Liu and Changhong Zhao and Zhiyuan Ma and Wei Wei},
  doi = {https://doi.org/10.1016/j.sysconle.2019.104607},
  url = {https://www.sciencedirect.com/science/article/pii/S0167691119302178},
  issn = {0167-6911},
  journal = {Syst. Control Lett.},
  pages = {104607},
  year = {2020},
  abstract = {This work addresses the distributed frequency control problem in power systems considering controllable load with a nonsmooth cost. The nonsmoothness exists widely in power systems, such as tiered price, greatly challenging the design of distributed optimal controllers. In this paper, we first formulate an optimization problem that minimizes the nonsmooth regulation cost, where both capacity limits of controllable load and tie-line flow are considered. Then, a distributed controller is derived based on the primal–dual gradient method, where the Clark generalized gradient is utilized to address the nonsmoothness. We also prove the optimality of the equilibrium of the closed-loop system as well as its stability. Simulations carried out on the IEEE 68-bus system verifies the effectiveness of the proposed method.},
  volume = {136},
  title = {Distributed optimal load frequency control considering nonsmooth cost functions},
  keywords = {Nonsmooth optimization, Distributed control, Load frequency control, Clark generalized gradient},
}

