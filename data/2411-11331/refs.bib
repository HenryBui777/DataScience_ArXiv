@article{chi2023,
  author = {J.H. Chi and Y. Qiang and C.Y. Gao and J.C. Pei},
  doi = {https://doi.org/10.1016/j.nuclphysa.2023.122626},
  url = {https://www.sciencedirect.com/science/article/pii/S0375947423000295},
  issn = {0375-9474},
  journal = {Nuclear Physics A},
  pages = {122626},
  year = {2023},
  abstract = {In this work, the multipole deformation-constrained Skyrme Hartree-Fock+BCS (SHF-BCS) calculations are implemented to obtain microscopic multi-dimensional potential energy surfaces for descriptions of fission of 240Pu. The SHF-BCS equation is solved in the axial-symmetric lattice space. The results show that the hexadecapole deformation is important at large deformations, and is related to issues of multiple solutions and discontinuities in potential energy surfaces. With a suitable disturbation of hexadecapole deformation β4, we can obtain a smooth 2-dimensional potential energy surface in (β2, β3) by parallel calculations. The constrained SHF-BCS calculation in the 3-dimensional deformation space of (β2, β3, β4) is also developed.},
  volume = {1032},
  title = {Role of hexadecapole deformation in fission potential energy surfaces of 240Pu},
  keywords = {Nuclear fission, Hexadecapole deformation},
}

