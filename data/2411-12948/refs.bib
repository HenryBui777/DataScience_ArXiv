@article{archaumbalt2024,
  author = {Archambault, Théo and Filoche, Arthur and Charantonis, Anastase and Béréziat, Dominique and Thiria, Sylvie},
  doi = {https://doi.org/10.1029/2023MS004047},
  url = {https://agupubs.onlinelibrary.wiley.com/doi/abs/10.1029/2023MS004047},
  eprint = {https://agupubs.onlinelibrary.wiley.com/doi/pdf/10.1029/2023MS004047},
  journal = {Journal of Advances in Modeling Earth Systems},
  pages = {e2023MS004047},
  abstract = {Abstract Satellite-based remote sensing missions have revolutionized our understanding of the Ocean state and dynamics. Among them, space-borne altimetry provides valuable Sea Surface Height (SSH) measurements, used to estimate surface geostrophic currents. Due to the sensor technology employed, important gaps occur in SSH observations. Complete SSH maps are produced using linear Optimal Interpolations (OI) such as the widely used Data Unification and Altimeter Combination System (duacs). On the other hand, Sea Surface Temperature (SST) products have much higher data coverage and SST is physically linked to geostrophic currents through advection. We propose a new multi-variate Observing System Simulation Experiment (OSSE) emulating 20 years of SSH and SST satellite observations. We train an Attention-Based Encoder-Decoder deep learning network (abed) on this data, comparing two settings: one with access to ground truth during training and one without. On our OSSE, we compare abed reconstructions when trained using either supervised or unsupervised loss functions, with or without SST information. We evaluate the SSH interpolations in terms of eddy detection. We also introduce a new way to transfer the learning from simulation to observations: supervised pre-training on our OSSE followed by unsupervised fine-tuning on satellite data. Based on real SSH observations from the Ocean Data Challenge 2021, we find that this learning strategy, combined with the use of SST, decreases the root mean squared error by 24\% compared to OI.},
  year = {2024},
  volume = {16},
  note = {e2023MS004047 2023MS004047},
  title = {Learning Sea Surface Height Interpolation From Multi-Variate Simulated Satellite Observations},
  keywords = {sea surface height, sea surface temperature, observing system simulation experiment, deep neural network, unsupervised, interpolation},
  number = {6},
}

