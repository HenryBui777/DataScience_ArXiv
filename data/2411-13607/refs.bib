@inproceedings{percivalEffectiveUseMultimedia2007,
  author = {Percival, Graham and Wang, Ye and Tzanetakis, George},
  doi = {10.1145/1290144.1290156},
  booktitle = {Proceedings of the International Workshop on {{Educational},
