@article{Lobaskin_2004_raspberry,
  doi = {10.1088/1367-2630/6/1/054},
  url = {https://dx.doi.org/10.1088/1367-2630/6/1/054},
  year = {2004},
  month = {may},
  publisher = {},
  volume = {6},
  number = {1},
  pages = {54},
  author = {Vladimir Lobaskin and Burkhard Dünweg},
  title = {A new model for simulating colloidal dynamics},
  journal = {New Journal of Physics},
  abstract = {We present a new hybrid lattice-Boltzmann and Langevin molecular dynamics scheme for simulating the dynamics of suspensions of spherical colloidal particles. The solvent is modelled on the level of the lattice-Boltzmann method whereas the molecular dynamics is done for the solute. The coupling between the two is implemented through a frictional force acting both on the solvent and on the solute, which depends on the relative velocity. A spherical colloidal particle is represented by interaction sites at its surface. We demonstrate that this scheme quantitatively reproduces the translational and rotational diffusion of a neutral spherical particle in a liquid and show preliminary results for a charged spherical particle. We argue that this method is especially advantageous in the case of charged colloids.},
}

@article{zottl_simulating_2018,
  title = {Simulating squirmers with multiparticle collision dynamics},
  volume = {41},
  issn = {1292-8941, 1292-895X},
  url = {http://arxiv.org/abs/1805.06416},
  doi = {10.1140/epje/i2018-11670-3},
  abstract = {Multiparticle collision dynamics is a modern coarse-grained simulation technique to treat the hydrodynamics of Newtonian ﬂuids by solving the Navier-Stokes equations. Naturally, it also includes thermal noise. Initially it has been applied extensively to spherical colloids or bead-spring polymers immersed in a ﬂuid. Here, we review and discuss the use of multiparticle collision dynamics for studying the motion of spherical model microswimmers called squirmers moving in viscous ﬂuids.},
  language = {en},
