  author = {Klie, Jan-Christoph and Webber, Bonnie and Gurevych, Iryna},
  year = {2023},
  pages = {157--198},
  file = {Klie et al. - 2023 - Annotation Error Detection Analyzing the Past and.pdf:/Users/lguerdan/Zotero/storage/BLREHG8X/Klie et al. - 2023 - Annotation Error Detection Analyzing the Past and.pdf:application/pdf},
}

