  number = {1},
  pages = {15},
  title = {{Revisiting the Properties of X-Ray Active Galactic Nuclei in the SSA22 Protocluster: Normal Supermassive Black Hole and Host-galaxy Growth for AGNs in a z = 3.09 Overdensity},
