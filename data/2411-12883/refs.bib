  keywords = {2435 Ionosphere: Ionospheric disturbances; 2483 Ionosphere: Wave/particle interactions; 7829 Space Plasma Physics: Kinetic waves and instabilities; 7839 Space Plasma Physics: Nonlinear phenomena; 7863 Space Plasma Physics: Turbulence; beam-plasma instability; ion-acoustic enhancements; weak turbulence},
  number = {A2},
}

