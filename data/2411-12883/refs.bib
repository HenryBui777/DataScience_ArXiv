@book{Yoon19,
  author = {Yoon, Peter H.},
  doi = {10.1017/9781316771259},
  place = {Cambridge},
  abstract = {Kinetic theory of weakly turbulent nonlinear processes in plasma helped form the foundation of modern plasma physics. This book provides a systematic overview of the kinetic theory of weak plasma turbulence from a modern perspective. It covers the fundamentals of weak turbulence theory, including the foundational concepts and the mathematical and technical details. Some key obstacles to space plasma applications are also covered, including the origin of non-thermal charged particle population, and radio burst phenomena from the sun. Treating both collective and discrete particle effects, the book provides a valuable reference for researchers looking to familiarize themselves with plasma weak turbulence theory.},
  publisher = {Cambridge University Press},
  address = {Cambridge},
  isbn = {9781316771259},
  year = {2019},
  localfile = {/home/rudi/Documents/Books/Physics/Plasmas/Yoon - Classical Kinetic Theory of Weakly Turbulent Nonlinear Plasma Processes (2019).pdf},
  note = {352 + xii pp.},
  title = {{Classical Kinetic Theory of Weakly Turbulent Nonlinear Plasma Processes},
}

