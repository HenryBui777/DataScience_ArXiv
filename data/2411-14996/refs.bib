@article{terwagne_metastable_2009,
  author = {Terwagne, D. and Gilet, T. and Vandewalle, N. and Dorbolo, S.},
  doi = {10.1063/1.3139138},
  url = {https://pubs.aip.org/pof/article/21/5/054103/934100/Metastable-bouncing-droplets},
  issn = {1070-6631, 1089-7666},
  journal = {Physics of Fluids},
  abstract = {An oil droplet is placed on an oil bath at least ten times more viscous. When the oil bath is vertically shaken according to a sinusoidal motion, the droplet may bounce indefinitely on the bath. This sustained bouncing mode is stable when the forcing acceleration is higher than a threshold value. On the other hand, the time of subsidence of the droplet on the bath is finite at weaker accelerations. The lifetime of bouncing droplets is measured for various viscosities and forcing parameters. The finiteness of the lifetime is correlated with the evolution of the interference fringe pattern made by the air film squeezed between the droplet and the bath when lighted by a monochromatic light. Finally, a model based on a combination of lubrication theory and droplet deformations rationalizes the experimental results.},
  year = {2009},
  pages = {054103},
  volume = {21},
  title = {Metastable bouncing droplets},
  urldate = {2024-04-30},
  number = {5},
}

