@inproceedings{ppc,
  author = {Zhao, Wenbing and Yang, Shunkun and Luo, Xiong and Zhou, Jiong},
  doi = {10.1145/3460537.3460547},
  url = {https://doi.org/10.1145/3460537.3460547},
  booktitle = {Proceedings of the 2021 3rd International Conference on Blockchain Technology},
  location = {Shanghai, China},
  publisher = {Association for Computing Machinery},
  year = {2021},
  address = {New York, NY, USA},
  isbn = {9781450389624},
  abstract = {Proof of Stake (PoS) has been talked about extensively as an alternative way of reaching consensus in blockchain systems. However, there are few publications on how PoS can be used to create new blocks in detail. The undisputed lead proponent for PoS is Ethereum. However, virtually all discussions regarding PoS for Ethereum are centered on selecting a block using PoS after one or more candidate blocks have already been somehow created. PeerCoin was the first blockchain system that incorporated PoS in block creation. Unfortunately, there is no known documentation on how PoS works in PeerCoin. In this paper, we fill this gap by presenting a detailed explanation of the PeerCoin PoS algorithm based on PeerCoin source code. We also dispel the misconception that PeerCoin PoS is based on Proof of Work (PoW) and hence would consume a lot of energy just like proof of work (PoW). In fact, it resembles PoW only on surface and differs from PoW substantially in terms of how to meet the difficulty target.},
  pages = {129–134},
  numpages = {6},
  series = {ICBCT '21},
  title = {On PeerCoin Proof of Stake for Blockchain Consensus},
  keywords = {Blockchain, PeerCoin, coin age, distributed consensus, proof of stake, proof of work, unspent transaction output (UTXO)},
}

@inproceedings{vrf,
  author = {Micali, Silvio and Vadhan, Salil and Rabin, Michael},
  booktitle = {Proceedings of the 40th Annual Symposium on Foundations of Computer Science},
  publisher = {IEEE Computer Society},
  year = {1999},
  address = {USA},
  isbn = {0769504094},
  abstract = {We efficiently combine unpredictability and verifiability by extending the Goldreich-Goldwasser-Micali construction of pseudorandom functions fs from a secret seed s, so that knowledge of s not only enables one to evaluate fs at any point x, but also to provide an NP-proof that the value fs(x) is indeed correct without compromising the unpredictability of fs at any other point for which no such a proof was provided.},
  pages = {120},
  series = {FOCS '99},
  title = {Verifiable Random Functions},
  keywords = {signature schemes, pseudorandom functions, RSA},
}

