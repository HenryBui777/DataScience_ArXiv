@article{bright_minidisk,
  author = {Bright, Jane C. and Paschalidis, Vasileios},
  doi = {10.1093/mnras/stad091},
  url = {http://arxiv.org/abs/2210.15686},
  annote = {Comment: Submitted to MNRAS. 10 pages, 10 figures},
  file = {arXiv.org Snapshot:/home/vik/Zotero/storage/JJ8GR76X/2210.html:text/html;Full Text PDF:/home/vik/Zotero/storage/XKLR7PJV/Bright and Paschalidis - 2023 - Minidisk Influence on Flow Variability in Accretin.pdf:application/pdf},
  issn = {0035-8711, 1365-2966},
  shorttitle = {Minidisk {Influence},
  journal = {Monthly Notices of the Royal Astronomical Society},
  abstract = {We perform magnetohydrodynamic simulations of accreting, equal-mass binary black holes in full general relativity focusing on the effect of spin and minidisks on the accretion rate and Poynting luminosity variability. We report on the structure of the minidisks and periodicities in the mass of the minidisks, mass accretion rates, and Poynting luminosity. The accretion rate exhibits a quasi-periodic behavior related to the orbital frequency of the binary in all systems that we study, but the amplitude of this modulation is dependent on the existence of persistent minidisks. In particular, systems that are found to produce persistent minidisks have a much weaker modulation of the mass accretion rate, indicating that minidisks can increase the inflow time of matter onto the black holes, and dampen out the quasi-periodic behavior. This finding has potential consequences for binaries at greater separations where minidisks can be much larger and may dampen out the periodicities significantly.},
  year = {2023},
  pages = {392--401},
  volume = {520},
  note = {arXiv:2210.15686 [astro-ph, physics:gr-qc]},
  title = {Minidisk {Influence},
  urldate = {2023-09-08},
  keywords = {Astrophysics - High Energy Astrophysical Phenomena, General Relativity and Quantum Cosmology, Astrophysics - Astrophysics of Galaxies},
  number = {1},
}

