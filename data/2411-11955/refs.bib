@article{graham_systematic_2015,
  author = {Graham, Matthew J. and Djorgovski, S. G. and Stern, Daniel and Drake, Andrew J. and Mahabal, Ashish A. and Donalek, Ciro and Glikman, Eilat and Larson, Steve and Christensen, Eric},
  doi = {10.1093/mnras/stv1726},
