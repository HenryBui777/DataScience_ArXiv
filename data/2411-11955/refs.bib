@article{rodriguez_2006,
  title = {A {Compact},
  volume = {646},
  issn = {0004-637X},
  url = {https://ui.adsabs.harvard.edu/abs/2006ApJ...646...49R},
  doi = {10.1086/504825},
  abstract = {We report on the discovery of a supermassive binary black hole system in the radio galaxy 0402+379, with a projected separation between the two black holes of just 7.3 pc. This is the closest black hole pair yet found by more than 2 orders of magnitude. These results are based on recent multifrequency observations using the Very Long Baseline Array (VLBA), which reveal two compact, variable, flat-spectrum, active nuclei within the elliptical host galaxy of 0402+379. Multiepoch observations from the VLBA also provide constraints on the total mass and dynamics of the system. Low spectral resolution spectroscopy using the Hobby-Eberly Telescope indicates two velocity systems with a combined mass of the two black holes of {\textasciitilde},
  urldate = {2023-09-28},
