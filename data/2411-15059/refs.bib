@article{leroy_simulating_2006,
  title = {Simulating a one-half spin with two coupled pendula: the free {Larmor},
  volume = {27},
  issn = {0143-0807, 1361-6404},
  shorttitle = {Simulating a one-half spin with two coupled pendula},
  url = {https://iopscience.iop.org/article/10.1088/0143-0807/27/6/011},
  doi = {10.1088/0143-0807/27/6/011},
  abstract = {It is shown that, with a simple two-pendulum device, one can experimentally simulate the behaviour of a one-half spin. After a quick overﬂight of the two-degree-of-freedom harmonic oscillator’s properties, we show that, in the quasi-degeneracy limit, this system is formally equivalent to a one-half spin: its physical states can be described by state vectors belonging to a twodimensional Hilbert space; its free motion obeys a Schro¨dinger equation. An R3-isomorphous representation space is used to illustrate this movement in terms of Larmor precession.},
  language = {en},
  number = {6},
  urldate = {2022-10-24},
  journal = {European Journal of Physics},
  author = {Leroy, V and Bacri, J-C and Hocquet, T and Devaud, M},
  year = {2006},
  pages = {1363--1383},
  file = {Leroy et al. - 2006 - Simulating a one-half spin with two coupled pendul.pdf:C\:\\Users\\apffel\\Zotero\\storage\\GJASHHRJ\\Leroy et al. - 2006 - Simulating a one-half spin with two coupled pendul.pdf:application/pdf},
}

