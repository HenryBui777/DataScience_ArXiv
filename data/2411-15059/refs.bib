@article{leroy_simulating_2010,
  title = {Simulating a one-half spin with two coupled pendula: {II},
  volume = {31},
  issn = {0143-0807, 1361-6404},
  shorttitle = {Simulating a one-half spin with two coupled pendula},
  url = {https://iopscience.iop.org/article/10.1088/0143-0807/31/1/015},
  doi = {10.1088/0143-0807/31/1/015},
  abstract = {It has already been shown that, with the simplest classical device, namely two coupled pendula, one can simulate the movement of a free quantum two-level system, as for instance a one-half spin in a static magnetic ﬁeld. We now show that, with a hardly more sophisticated device, one can simulate the latter system undergoing outer perturbation. In the case of sinusoidal excitation, we present an experimental mechanical illustration of the transition of the system between its two eigenstates, known as the Rabi precession. Abstract theoretical concepts of absorption and stimulated emission of energy are thus provided with intuitive support.},
  language = {en},
  number = {1},
  urldate = {2022-10-24},
  journal = {European Journal of Physics},
  author = {Leroy, V and Bacri, J-C and Hocquet, T and Devaud, M},
  year = {2010},
  pages = {157--170},
  file = {Leroy et al. - 2010 - Simulating a one-half spin with two coupled pendul.pdf:C\:\\Users\\apffel\\Zotero\\storage\\H7C9INEY\\Leroy et al. - 2010 - Simulating a one-half spin with two coupled pendul.pdf:application/pdf},
}

