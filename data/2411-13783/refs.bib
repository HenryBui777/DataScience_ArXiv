@article{zheng_optimal_2024,
  author = {Zheng, Rangrang and Schivley, Greg and Hidalgo-Gonzalez, Patricia and Fripp, Matthias and Roberts, Michael J.},
  url = {https://ideas.repec.org//p/hae/wpaper/2024-2.html},
