@article{Suter14,
  author = {Martin Suter and Peter Dietiker},
  journal = {Appl. Opt.},
  keywords = {Resonators; Resonance; Spectroscopy, laser; Absorption coefficient; Cavity ring down spectroscopy; Optical resonators; Q factor; Reflectivity; Refractive index},
  number = {30},
  pages = {7004--7010},
  publisher = {Optica Publishing Group},
  title = {Calculation of the finesse of an ideal Fabry\&\#x2013;Perot resonator},
  volume = {53},
  year = {2014},
  url = {https://opg.optica.org/ao/abstract.cfm?URI=ao-53-30-7004},
  doi = {10.1364/AO.53.007004},
  abstract = {A new derivation of an exact finesse F for the description of an optical resonator is reported. The finesse is derived using the superposition principle of plane waves in an ideal Fabry\&\#x2013;Perot resonator in combination with the standard definition of the quality factor Q which relates the energy loss of a resonator cycle to the energy stored in the resonator. The derived exact expression of the finesse is compared to equations found in the literature, and it is shown that they are based on approximations. The exact finesse is then used to convert an infinite series of Lorentz functions into the well-known Airy equation in the case of neglected absorption. The derived expression provides a framework for the discussion of the finesse in terms of decay times, free spectral ranges, and resonator line widths. The provided expression for the finesse is valid for any value of the intensity reflectivity and gives insight into the underlying physical principles of resonators.},
}

