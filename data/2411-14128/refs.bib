@article{Takano17,
  doi = {10.7567/APEX.10.072801},
  url = {https://dx.doi.org/10.7567/APEX.10.072801},
  year = {2017},
  publisher = {The Japan Society of Applied Physics},
  volume = {10},
  number = {7},
  pages = {072801},
  author = {Tetsushi Takano and Ray Mizushima and Hidetoshi Katori},
  title = {Precise determination of the isotope shift of 88Sr–87Sr optical lattice clock by sharing perturbations},
  journal = {Applied Physics Express},
  abstract = {We report on the isotope shift between 88Sr and 87Sr on the 1S0–3P0 clock transitions. The interleaved operation of an optical lattice clock with two isotopes allows the canceling out of common perturbations, such as the quadratic Zeeman shift, the clock-light shift, and the blackbody radiation shift. The isotope shift is determined to be 62 188 134.004(10) Hz, where the major uncertainty is introduced by the collisional shift that is distinct for each isotope. Our result allows us to determine the frequency of 88Sr–87Sr optical lattice clocks with a fractional uncertainty of 2 × 10−17. The scheme is generally applicable for measuring the isotope shift with significantly reduced uncertainty.},
}

