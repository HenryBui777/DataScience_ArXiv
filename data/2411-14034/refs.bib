@article{zno:al,
  title = {Growth of transparent conducting nanocrystalline $\text{Al},
  journal = {Journal of Crystal Growth},
  volume = {294},
  number = {2},
  pages = {427-431},
  year = {2006},
  issn = {0022-0248},
  doi = {https://doi.org/10.1016/j.jcrysgro.2006.06.035},
  url = {https://www.sciencedirect.com/science/article/pii/S0022024806006178},
  author = {R.K. Shukla and Anchal Srivastava and Atul Srivastava and K.C. Dubey},
  keywords = {A1. Nanocrystalline, A1. Optical transparency, A1. Transmission window, A3. Pulsed laser deposition, Bl. Al doped ZnO films, B2. Low electrical resistivity},
  abstract = {Nanocrystalline thin films of Al doped ZnO (Al:0–5at%) with low electrical resistivity and high optical transparency have been grown by pulsed laser deposition. X-ray diffraction patterns showed the presence of hexagonal wurtzite ZnO phase with strong c-axis orientation in all the cases. The c-axis lattice parameter was found to increase with increase in Al doping. The average grain size in the film decreases from ∼38 to ∼25nm with increasing Al concentration from 0 to 5at%. For a critical doping of 2at%, the resistivity of the AZO film is minimum (6×10−4Ω-cm) and the average optical transparency is nearly 85%. The band gap increases with increase in doping which is in accordance to Burstein–Moss shift. A blue shift in the absorption edge of ZnO with increasing Al concentration in the film is noteworthy as it leads to increase in the width of the transmission window.},
}
