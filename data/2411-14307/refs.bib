  url = {https://dx.doi.org/10.1088/0264-9381/26/4/045018},
  journal = {Class. Quantum Gravity},
  publisher = {},
  year = {2009},
  pages = {045018},
  abstract = {For spacetimes with timelike Killing fields, we introduce a ‘Fermi–Walker–Killing’ coordinate system and use it to prove a Liouville theorem for an appropriate volume element of phase space for a statistical mechanical system of particles. We derive an exact relativistic formula for the Helmholtz free energy of an ideal gas and compare it, for a class of spacetimes, to its Newtonian analog, derived both independently and as the Newtonian limit of our formula. We also find the relativistic thermodynamic equation of state. Specific examples are given in Kerr spacetime.},
  volume = {26},
  title = {Timelike Killing fields and relativistic statistical mechanics},
  month = {feb},
  number = {4},
}

