  issn = {0370-1573},
  journal = {Physics Reports},
  pages = {183},
  year = {1980},
  abstract = {I discuss the reasons for believing that phase transitions occurred in the very early history of the universe, and the topological structures that may have been generated thereby-in particular, the strings and monopoles. The aim is mainly pedagogical, with special emphasis on unsolved problems.},
  volume = {67},
  title = {Some implications of a cosmological phase transition},
  number = {1},
}

@article{Kibble1976,
