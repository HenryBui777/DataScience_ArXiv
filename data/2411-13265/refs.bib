  pages = {463--474},
  file = {Full Text PDF:C\:\\Users\\Skoul-Portable\\Zotero\\storage\\6CGLFHSX\\Kolb et al. - 2019 - Automated electron diffraction tomography – development and applications.pdf:application/pdf},
}

@article{klar_accurate_2023,
  title = {Accurate structure models and absolute configuration determination using dynamical effects in continuous-rotation {3D},
  volume = {15},
  copyright = {2023 The Author(s)},
  issn = {1755-4349},
  url = {https://www.nature.com/articles/s41557-023-01186-1},
  doi = {10.1038/s41557-023-01186-1},
  abstract = {Continuous-rotation 3D electron diffraction methods are increasingly popular for the structure analysis of very small organic molecular crystals and crystalline inorganic materials. Dynamical diffraction effects cause non-linear deviations from kinematical intensities that present issues in structure analysis. Here, a method for structure analysis of continuous-rotation 3D electron diffraction data is presented that takes multiple scattering effects into account. Dynamical and kinematical refinements of 12 compounds—ranging from small organic compounds to metal–organic frameworks to inorganic materials—are compared, for which the new approach yields significantly improved models in terms of accuracy and reliability with up to fourfold reduction of the noise level in difference Fourier maps. The intrinsic sensitivity of dynamical diffraction to the absolute structure is also used to assign the handedness of 58 crystals of 9 different chiral compounds, showing that 3D electron diffraction is a reliable tool for the routine determination of absolute structures.},
  language = {en},
  number = {6},
  urldate = {2024-10-31},
  journal = {Nature Chemistry},
  author = {Klar, Paul B. and Krysiak, Yaşar and Xu, Hongyi and Steciuk, Gwladys and Cho, Jung and Zou, Xiaodong and Palatinus, Lukas},
  year = {2023},
  note = {Publisher: Nature Publishing Group},
  keywords = {Analytical chemistry, Materials chemistry, Techniques and instrumentation},
  pages = {848--855},
  file = {Full Text PDF:C\:\\Users\\Skoul-Portable\\Zotero\\storage\\26J8BNES\\Klar et al. - 2023 - Accurate structure models and absolute configuration determination using dynamical effects in contin.pdf:application/pdf},
}

@incollection{yokoyama_chapter_2008,
  address = {Amsterdam},
  title = {{CHAPTER},
  isbn = {978-0-444-53122-3},
  url = {https://www.sciencedirect.com/science/article/pii/B9780444531223500040},
  abstract = {This chapter presents an introduction to nanoparticles and their properties. Nanoparticles are ultrafine particles in the size of nanometer order. The characteristics of nanosized magnetic substance are deviated from the bulk ones. One of major reasons for the unique properties of the nanoparticles different from the bulk material is the increase in specific surface area with micronization of particle, influencing their properties like the solution and reaction rates of the particles. For nanoparticles, the number of atoms, ions, or molecules making up the particle becomes larger on the surface rather than within the particle. For this reason, a number of unique characteristics specific to nanoparticles appear. These characteristics give strong effects not only to quantum size effect specific to nanoparticles but also to phenomena relating to powder handling such as adhesion and coagulation. Magnetic characteristics such as saturation magnetization decrease proportionally with size reduction of magnetic substance. Optical property of nanoparticle is greatly different according to whether the nanoparticle is insulator, semiconductor, or metal. The optical properties of nanoparticles are measured with spectrometry systems that are generally used for ordinary powder particles. The electrical properties such as dielectric and ferroelectric properties are the intrinsic independent of the shape and size. However, it is very difficult to estimate the electrical properties of the nanoparticles. The dielectric constant of nanoparticles can be estimated by analyzing the phonon modes of Raman spectra.},
  urldate = {2024-10-31},
  booktitle = {Nanoparticle {Technology},
  publisher = {Elsevier},
  author = {Yokoyama, Toyokazu and Masuda, Hiroaki and Suzuki, Michitaka and Ehara, Kensei and Nogi, Kiyoshi and Fuji, Masayoshi and Fukui, Takehisa and Suzuki, Hisao and Tatami, Junichi and Hayashi, Kazuyuki and Toda, Kenji},
  editor = {Hosokawa, Masuo and Nogi, Kiyoshi and Naito, Mario and Yokoyama, Toyokazu},
  year = {2008},
  doi = {10.1016/B978-044453122-3.50004-0},
  pages = {3--48},
  file = {ScienceDirect Full Text PDF:C\:\\Users\\Skoul-Portable\\Zotero\\storage\\7GYNBEUV\\Yokoyama et al. - 2008 - CHAPTER 1 - BASIC PROPERTIES AND MEASURING METHODS OF NANOPARTICLES.pdf:application/pdf;ScienceDirect Snapshot:C\:\\Users\\Skoul-Portable\\Zotero\\storage\\3ZTVQBDH\\B9780444531223500040.html:text/html},
}

@article{ishikawa_quantitative_2014,
  title = {Quantitative {Annular},
  volume = {20},
  issn = {1431-9276, 1435-8115},
  url = {https://www.cambridge.org/core/journals/microscopy-and-microanalysis/article/abs/quantitative-annular-dark-field-electron-microscopy-using-single-electron-signals/1EFA47D9FEBE98289C775F20D74C4115},
  doi = {10.1017/S1431927613013664},
  abstract = {One of the difficulties in analyzing atomic resolution electron microscope images is that the sample thickness is usually unknown or has to be fitted from parameters that are not precisely known. An accurate measure of thickness, ideally on a column-by-column basis, parameter free, and with single atom accuracy, would be of great value for many applications, such as matching to simulations. Here we propose such a quantification method for annular dark field scanning transmission electron microscopy by using the single electron intensity level of the detector. This method has the advantage that we can routinely quantify annular dark field images operating at both low and high beam currents, and under high dynamic range conditions, which is useful for the quantification of ultra-thin or light-element materials. To facilitate atom counting at the atomic scale we use the mean intensity in an annular dark field image averaged over a primitive cell, with no free parameters to be fitted. To illustrate the potential of our method, we demonstrate counting the number of Al (or N) atoms in a wurtzite-type aluminum nitride single crystal at each primitive cell over the range of 3–99 atoms.},
  language = {en},
  number = {1},
  urldate = {2024-10-31},
  journal = {Microscopy and Microanalysis},
  author = {Ishikawa, Ryo and Lupini, Andrew R. and Findlay, Scott D. and Pennycook, Stephen J.},
  year = {2014},
  keywords = {aberration correction, ADF, counting atoms, EELS, image simulation, quantitative microscopy, single electron, STEM},
  pages = {99--110},
}

@article{krivanek_gentle_2010,
  series = {{PROCEEDINGS},
  title = {Gentle {STEM},
  volume = {110},
  issn = {0304-3991},
  shorttitle = {Gentle {STEM},
  url = {https://www.sciencedirect.com/science/article/pii/S0304399110000343},
  doi = {10.1016/j.ultramic.2010.02.007},
  abstract = {Aberration correction of the scanning transmission electron microscope (STEM) has made it possible to reach probe sizes close to 1Å at 60keV, an operating energy that avoids direct knock-on damage in materials consisting of light atoms such as B, C, N and O. Although greatly reduced, some radiation damage is still present at this energy, and this limits the maximum usable electron dose. Elemental analysis by electron energy loss spectroscopy (EELS) is then usefully supplemented by annular dark field (ADF) imaging, for which the signal is larger. Because of its strong Z dependence, ADF allows the chemical identification of individual atoms, both heavy and light, and it can also record the atomic motion of individual heavy atoms in considerable detail. We illustrate these points by ADF images and EELS of nanotubes containing nanopods filled with single atoms of Er, and by ADF images of graphene with impurity atoms.},
  number = {8},
  urldate = {2024-10-31},
  journal = {Ultramicroscopy},
  author = {Krivanek, Ondrej L. and Dellby, Niklas and Murfitt, Matthew F. and Chisholm, Matthew F. and Pennycook, Timothy J. and Suenaga, Kazutomo and Nicolosi, Valeria},
  year = {2010},
  keywords = {Aberration correction, ADF, EELS, Graphene, Nanotube, STEM},
  pages = {935--945},
  file = {ScienceDirect Full Text PDF:C\:\\Users\\Skoul-Portable\\Zotero\\storage\\I3QZ9M4B\\Krivanek et al. - 2010 - Gentle STEM ADF imaging and EELS at low primary energies.pdf:application/pdf;ScienceDirect Snapshot:C\:\\Users\\Skoul-Portable\\Zotero\\storage\\4WLQYCZP\\S0304399110000343.html:text/html},
}

