  url = {https://dx.doi.org/10.1088/1742-6596/644/1/012038},
  doi = {10.1088/1742-6596/644/1/012038},
  abstract = {We have studied the impact of transmission electron microscopy (TEM) and low dose electron diffraction on ten different crystalline pharmaceutical compounds, covering a diverse chemical space and with differing physical properties. The aim was to establish if particular chemical moieties were more susceptible to damage within the electron beam. We have measured crystalline diffraction patterns for each and indexed nine out of ten of them. Characteristic electron dosages are reported for each material, with no apparent correlation between chemical structure and stability within the electron beam. Such low dose electron diffraction protocols are suitable for the study of pharmaceutical compounds.},
  language = {en},
  number = {1},
  urldate = {2024-10-30},
