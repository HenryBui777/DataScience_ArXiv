@article{Xiao2024,
  title = {A machine learning-based high-precision density functional method for drug-like molecules},
  journal = {Artificial Intelligence Chemistry},
  volume = {2},
  number = {1},
  pages = {100037},
  year = {2024},
  issn = {2949-7477},
  doi = {https://doi.org/10.1016/j.aichem.2023.100037},
  url = {https://www.sciencedirect.com/science/article/pii/S2949747723000374},
  author = {Jin Xiao and YiXiao Chen and LinFeng Zhang and Han Wang and Tong Zhu},
  keywords = {Machine Learning, Density Functional Theory, DeePHF, DeePKS},
  abstract = {In computer-aided drug discovery, accurately determining the structure and properties of drug-like molecules is of utmost importance. This necessitates the use of precise and efficient electronic structure methods. Here, we developed two deep learning-based density functional methods, namely DeePHF and DeePKS, specifically tailored for drug-like molecules. Notably, DeePKS incorporates self-consistency into its framework. With a limited dataset labelled at the CCSD(T)/def2-TZVP level, both models have been able to achieve chemical accuracy in calculating molecular energies and have demonstrated excellent transferability. We anticipate that further advancements in this field will lead to the development of high-quality density functional methods designed specifically for drug discovery purposes. This research showcases the capabilities of deep learning approaches in simplifying the construction complexity associated with traditional DFT methods.},
}

@article{Pople1978,
  title = {Computation of electron repulsion integrals involving contracted Gaussian basis functions},
  journal = {Journal of Computational Physics},
  volume = {27},
  number = {2},
  pages = {161-168},
  year = {1978},
  issn = {0021-9991},
  doi = {https://doi.org/10.1016/0021-9991(78)90001-3},
  url = {https://www.sciencedirect.com/science/article/pii/0021999178900013},
  author = {John A Pople and Warren J Hehre},
  abstract = {A computational procedure is outlined for efficient evaluation of four-center coulomb repulsion integrals using contracted Gaussian basis functions. By utilizing information common to a shell of basis functions (such as s, px, py, and pz) and by transforming to alternative axes within the contraction loops, this method achieves high efficiency. The technique has been incorporated into the GAUSSIAN-70 molecular orbital program.},
}

@incollection{Gill1994,
  title = {Molecular integrals Over Gaussian Basis Functions},
  editor = {John R. Sabin and Michael C. Zerner},
  series = {Advances in Quantum Chemistry},
  publisher = {Academic Press},
  volume = {25},
  pages = {141-205},
  year = {1994},
  issn = {0065-3276},
  doi = {https://doi.org/10.1016/S0065-3276(08)60019-2},
  url = {https://www.sciencedirect.com/science/article/pii/S0065327608600192},
  author = {Peter M.W. Gill},
  abstract = {Publisher Summary
The major goal of quantum chemistry is to obtain solutions to atomic and molecular Schrodinger equations. The most uniformly successful family of methods begins with the simplest possible n-electron wave function satisfying the Pauli antisymmetry principle—a Slater determinant of one-electron functions χi(r,$\omega$) called “spinorbitals.” Each spinorbital is a product of a molecular orbital and a spinfunction. The molecular orbital are found by the self-consistent-field (SCF) procedure. The Hartree-Fock (HF) and Kohn-Sham density functional (KS) theories are both of this type, as are their many simplified variants. The result of any quantum chemical procedure is the molecular energy, parametrically determined by the nuclear geometry. To locate equilibrium and transition structures, usually the first derivatives of the energy are computed with respect to nuclear motion; harmonic vibrational frequencies can be obtained if second derivatives are available and third and higher derivatives are needed for higher-level studies of potential surfaces. It is noted that the nth derivatives of the integrals are required to compute nth-derivatives of the energy. This chapter focuses on the efficient generation of integrals and their nth-derivatives.},
}

