  pages = {257},
  language = {en},
  abstract = {This thesis addresses the model order reduction of geometrically nonlinear structural dynamics systems with focus on simulation-free methods, which do not require expensive training simulations of the original model. This work covers both reduced basis methods and hyper-reduction methods which are necessary to reduce the costs associated with the computation of the nonlinear forces. The successful applicability of the discussed and newly proposed methods is demonstrated on various examples.},
  keywords = {model order reduction, simulation-free, hyper-reduction, nonlinear finite elements},
}

