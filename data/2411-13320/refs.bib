  author = {Noguchi, Ryo and Kobayashi, Masaru and Jiang, Zhanzhi and Kuroda, Kenta and Takahashi, Takanari and Xu, Zifan and Lee, Daehun and Hirayama, Motoaki and Ochi, Masayuki and Shirasawa, Tetsuroh and Zhang, Peng and Lin, Chun and Bareille, C{\'e},
