@article{zhaoTopological2023,
  title = {Topological Electronic Structure and Spin Texture of Quasi-One-Dimensional Higher-Order Topological Insulator {{Bi},
  author = {Zhao, Wenxuan and Yang, Ming and Xu, Runzhe and Du, Xian and Li, Yidian and Zhai, Kaiyi and Peng, Cheng and Pei, Ding and Gao, Han and Li, Yiwei and Xu, Lixuan and Han, Junfeng and Huang, Yuan and Liu, Zhongkai and Yao, Yugui and Zhuang, Jincheng and Du, Yi and Zhou, Jinjian and Chen, Yulin and Yang, Lexian},
  year = {2023},
