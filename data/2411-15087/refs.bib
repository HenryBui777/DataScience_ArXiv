  file = {Preprint PDF:/Users/nero1342/Zotero/storage/A5GHEE3U/Nguyen-Truong et al. - 2024 - Vision-Aware Text Features in Referring Image Segm.pdf:application/pdf;Snapshot:/Users/nero1342/Zotero/storage/RXLG6CG7/2404.html:text/html},
}

@inproceedings{wu_language_2022,
  address = {New Orleans, LA, USA},
  title = {Language as {Queries},
  copyright = {https://doi.org/10.15223/policy-029},
