}

@inproceedings{yu_mattnet_2018,
  address = {Salt Lake City, UT},
  title = {{MAttNet},
  isbn = {978-1-5386-6420-9},
  shorttitle = {{MAttNet},
  url = {https://ieeexplore.ieee.org/document/8578240/},
  doi = {10.1109/CVPR.2018.00142},
  abstract = {In this paper, we address referring expression comprehension: localizing an image region described by a natural language expression. While most recent work treats expressions as a single unit, we propose to decompose them into three modular components related to subject appearance, location, and relationship to other objects. This allows us to ﬂexibly adapt to expressions containing different types of information in an end-to-end framework. In our model, which we call the Modular Attention Network (MAttNet), two types of attention are utilized: languagebased attention that learns the module weights as well as the word/phrase attention that each module should focus on; and visual attention that allows the subject and relationship modules to focus on relevant image components. Module weights combine scores from all three modules dynamically to output an overall score. Experiments show that MAttNet outperforms previous state-of-the-art methods by a large margin on both bounding-box-level and pixel-level comprehension tasks. Demo1 and code2 are provided.},
  language = {en},
  urldate = {2024-10-27},
