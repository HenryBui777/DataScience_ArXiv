  file = {Ding et al. - 2021 - Vision-Language Transformer and Query Generation f.pdf:/Users/nero1342/Zotero/storage/6I37XLZP/Ding et al. - 2021 - Vision-Language Transformer and Query Generation f.pdf:application/pdf},
