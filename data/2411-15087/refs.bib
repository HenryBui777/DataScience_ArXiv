  file = {Chng et al. - 2024 - Mask Grounding for Referring Image Segmentation.pdf:/Users/nero1342/Zotero/storage/HYGKLR3J/Chng et al. - 2024 - Mask Grounding for Referring Image Segmentation.pdf:application/pdf},
}

