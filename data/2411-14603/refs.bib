@article{henson_2000,
  title = {Multiple attractors and resonance in periodically forced population models},
  volume = {140},
  issn = {0167-2789},
  url = {https://www.sciencedirect.com/science/article/pii/S0167278999002316},
  doi = {10.1016/S0167-2789(99)00231-6},
  abstract = {Oscillating discrete autonomous dynamical systems admit multiple oscillatory solutions in the advent of periodic forcing. The multiple cycles are out of phase, and some of their averages may resonate with the forcing amplitude while others attenuate. In application to population biology, populations with stable inherent oscillations in constant habitats are predicted to develop multiple attracting oscillatory final states in the presence of habitat periodicity. The average total population size may resonate or attenuate with the amplitude of the environmental fluctuation depending on the initial population size. The theory has been tested successfully in the laboratory by subjecting cultures of the flour beetle Tribolium to habitat periodicity of various amplitudes.},
  number = {1},
  urldate = {2023-09-15},
  journal = {Physica D: Nonlinear Phenomena},
  author = {Henson, Shandelle M.},
  year = {2000},
  keywords = {Multiple attractors, Periodic forcing, Periodic habitats, Population dynamics},
  pages = {33--49},
  file = {ScienceDirect Full Text PDF:/Users/samanthabrozak/Zotero/storage/IZIB4P66/Henson - 2000 - Multiple attractors and resonance in periodically .pdf:application/pdf;ScienceDirect Snapshot:/Users/samanthabrozak/Zotero/storage/UIITZLFF/S0167278999002316.html:text/html},
}

