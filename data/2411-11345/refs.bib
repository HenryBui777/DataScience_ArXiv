@article{ZonAlg,
  author = {Paul Breiding and Peter Bürgisser and Antonio Lerario and Léo Mathis},
  doi = {https://doi.org/10.1016/j.aim.2022.108361},
  url = {https://www.sciencedirect.com/science/article/pii/S0001870822001773},
  issn = {0001-8708},
  journal = {Advances in Mathematics},
  pages = {108361},
  year = {2022},
  abstract = {We show that every multilinear map between Euclidean spaces induces a unique, continuous, Minkowski multilinear map of the corresponding real cones of zonoids. Applied to the wedge product of the exterior algebra of a Euclidean space, this yields a multiplication of zonoids, defining the structure of a commutative, associative, and partially ordered ring, which we call the zonoid algebra. This framework gives a new perspective on classical objects in convex geometry, and it allows to introduce new functionals on zonoids, in particular generalizing the notion of mixed volume. We also analyze a similar construction based on the complex wedge product, which leads to the new notion of mixed J–volume. These ideas connect to the theory of random determinants.},
  volume = {402},
  title = {The zonoid algebra, generalized mixed volumes, and random determinants},
  keywords = {Zonoids, Random determinant, Convex bodies, Mixed volume},
}

