@article{andreevbits,
  author = {Aguado, Ramón},
  doi = {10.1063/5.0024124},
  url = {https://doi.org/10.1063/5.0024124},
  file = {Full Text PDF:/Users/siddhantm/Zotero/storage/XIV58WPU/Aguado - 2020 - A perspective on semiconductor-based superconducti.pdf:application/pdf;Snapshot:/Users/siddhantm/Zotero/storage/CA6ZQEWI/39211.html:text/html},
  issn = {0003-6951},
  journal = {Applied Physics Letters},
  abstract = {Following the demonstration of semiconductor-based Josephson junctions, which are fully tunable by electrical means, new routes have been opened for the study of hybrid semiconductor–superconductor qubits. These include semiconductor-based transmon qubits, single-spin Andreev qubits, and fault-tolerant topological qubits based on Majorana zero modes. In this perspective, we review recent progress in the path toward such hybrid qubit designs. After a short introduction and a brief digression about the historical roadmap that has led to the experimental state-of-the-art, the emphasis is placed on superconducting qubits based on semiconductor nanowires.},
  year = {2020},
  pages = {240501},
  volume = {117},
  title = {A perspective on semiconductor-based superconducting qubits},
  urldate = {2023-11-07},
  number = {24},
}

