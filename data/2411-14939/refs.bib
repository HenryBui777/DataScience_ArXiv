@article{sun_analyses_2012,
  title = {Analyses about efficiency of reinforcement learning to supply chain ordering management},
  doi = {10.1109/INDIN.2012.6301163},
  abstract = {The Reinforcement Learning (RL) is an efficient machine learning method for solving problems that an agent has no knowledge about the environment a priori. Improving efficiency of decision-making practices in a supply chain is a major competitive domain in today's uncertain business environments. The bullwhip effect is an important phenomenon in the supply chain, in which the order variability increases as moving up along the supply chain. This paper proposes a multiagent coordination mechanism utilizing RL method to the supply chain ordering management. Further, the analyses about the efficiency of the method are discussed in detail based on some representative test data. Results show that the RL agent reduces the bullwhip effect efficiently in the stochastic supply chain.},
  journal = {{IEEE},
  author = {Sun, R. and Zhao, G.},
  year = {Beijing, China, July 25-27 2012},
  keywords = {reinforcement learning, supply chain management, Learning, bullwhip, bullwhip effect, business environments, Conferences, decision making, decision-making practices, machine learning method, multi-agent systems, multiagent coordination mechanism, NP-hard problem, ordering management, problem solving, stochastic, stochastic supply chain, Sun, supply chain, Supply chain management, supply chain ordering management, Supply chains},
