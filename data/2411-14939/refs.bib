@misc{motamedi_demand_2021,
  title = {Demand forecasting for platelet usage: from univariate time series to multivariate models},
  shorttitle = {Demand {Forecasting},
  howpublished = {arXiv},
  url = {http://arxiv.org/abs/2101.02305},
  abstract = {Platelet products are both expensive and have very short shelf lives. As usage rates for platelets are highly variable, the effective management of platelet demand and supply is very important yet challenging. The primary goal of this paper is to present an efficient forecasting model for platelet demand at Canadian Blood Services (CBS). To accomplish this goal, four different demand forecasting methods, ARIMA (Auto Regressive Moving Average), Prophet, lasso regression (least absolute shrinkage and selection operator) and LSTM (Long Short-Term Memory) networks are utilized and evaluated. We use a large clinical dataset for a centralized blood distribution centre for four hospitals in Hamilton, Ontario, spanning from 2010 to 2018 and consisting of daily platelet transfusions along with information such as the product specifications, the recipients' characteristics, and the recipients' laboratory test results. This study is the first to utilize different methods from statistical time series models to data-driven regression and a machine learning technique for platelet transfusion using clinical predictors and with different amounts of data. We find that the multivariate approaches have the highest accuracy in general, however, if sufficient data are available, a simpler time series approach such as ARIMA appears to be sufficient. We also comment on the approach to choose clinical indicators (inputs) for the multivariate models.},
  journal = {arXiv:2101.02305 [cs.LG]},
  author = {Motamedi, Maryam and Li, Na and Down, Douglas G. and Heddle, Nancy M.},
  year = {2021},
  keywords = {demand forecasting, platelets, statistical time-series modelling, hold-out, perishable, canada, key, ML transfusion review, inventory, in overleaf, recurrent neural network},
  file = {arXiv Fulltext PDF:C\:\\Users\\joefa\\Zotero\\storage\\LVFYKFU3\\LVFYKFU3.pdf:application/pdf;arXiv.org Snapshot:C\:\\Users\\joefa\\Zotero\\storage\\X4Z2ABHN\\2101.html:text/html},
}

@article{Guan2017d,
  title = {Big data modeling to predict platelet usage and minimize wastage in a tertiary care system},
  volume = {114},
  issn = {10916490},
  url = {https://doi.org/10.1073/pnas.171409711},
  doi = {10.1073/pnas.1714097114},
  abstract = {Maintaining a robust blood product supply is an essential requirement to guarantee optimal patient care in modern health care systems. However, daily blood product use is difficult to anticipate. Platelet products are the most variable in daily usage, have short shelf lives, and are also the most expensive to produce, test, and store. Due to the combination of absolute need, uncertain daily demand, and short shelf life, platelet products are frequently wasted due to expiration. Our aim is to build and validate a statistical model to forecast future platelet demand and thereby reduce wastage. We have investigated platelet usage patterns at our institution, and specifically interrogated the relationship between platelet usage and aggregated hospitalwide patient data over a recent consecutive 29-mo period. Using a convex statistical formulation, we have found that platelet usage is highly dependent on weekday/weekend pattern, number of patients with various abnormal complete blood count measurements, and location-specific hospital census data. We incorporated these relationships in a mathematical model to guide collection and ordering strategy. This model minimizes waste due to expiration while avoiding shortages; the number of remaining platelet units at the end of any day stays above 10 in our model during the same period. Compared with historical expiration rates during the same period, our model reduces the expiration rate from 10.5 to 3.2\%. Extrapolating our results to the {\textasciitilde},
  number = {43},
  journal = {P. Natl. Acad. Sci. USA},
  author = {Guan, Leying and Tian, Xiaoying and Gombar, Saurabh and Zemek, Allison J. and Krishnan, Gomathi and Scott, Robert and Narasimhan, Balasubramanian and Tibshirani, Robert J. and Pham, Tho D.},
  year = {2017},
  keywords = {demand forecasting, in overleaf, inventory, key, ML transfusion review, perishable, platelets, replenishment, supervised learning, united states},
  pages = {11368--11373},
  file = {Guan et al. - 2017 - Big data modeling to predict platelet usage and minimize wastage in a tertiary care system.pdf:C\:\\Users\\joefa\\Zotero\\storage\\UDVY3NQ9\\UDVY3NQ9.pdf:application/pdf},
}

@phdthesis{Dumkreiger2020,
  address = {Phoenix, AZ, USA},
