@article{Medenjak2017,
  abstract = {We establish a general connection between ballistic and diffusive transport in systems where the ballistic contribution in canonical ensemble vanishes. A lower bound on the Green-Kubo diffusion constant is derived in terms of the curvature of the ideal transport coefficient, the Drude weight, with respect to the filling parameter. As an application, we explicitly determine the lower bound on the high temperature diffusion constant in the anisotropic spin 1/2 Heisenberg chain for anisotropy parameters $\Delta \geq 1$, thus settling the question whether the transport is sub-diffusive or not. Addi- tionally, the lower bound is shown to saturate the diffusion constant for a certain classical integrable model.},
  archiveprefix = {arXiv},
  arxivid = {1702.04677},
  author = {Medenjak, Marko and Karrasch, Christoph and Prosen, Toma{\v{z},
  doi = {10.1103/PhysRevLett.119.080602},
  eprint = {1702.04677},
  file = {:Users/kormos/Mendeley Desktop/2017/Medenjak, Karrasch, Prosen/Medenjak, Karrasch, Prosen - 2017 - Lower Bounding Diffusion Constant by the Curvature of Drude Weight.pdf:pdf},
  issn = {0031-9007},
  journal = {Phys. Rev. Lett.},
  xmonth = {aug},
  xnumber = {8},
  pages = {080602},
  title = {{Lower Bounding Diffusion Constant by the Curvature of Drude Weight},
  xxurl = {http://arxiv.org/abs/1702.04677 http://dx.doi.org/10.1103/PhysRevLett.119.080602 https://link.aps.org/doi/10.1103/PhysRevLett.119.080602},
  volume = {119},
  year = {2017},
}

