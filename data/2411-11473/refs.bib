@article{doi:10.1126/science.adk8978,
  author = {Kangning Yang  and Yicheng Zhang  and Kuan-Yu Li  and Kuan-Yu Lin  and Sarang Gopalakrishnan  and Marcos Rigol  and Benjamin L. Lev},
  title = {Phantom energy in the nonlinear response of a quantum many-body scar state},
  journal = {Science},
  volume = {385},
  number = {6713},
  pages = {1063-1067},
  year = {2024},
  doi = {10.1126/science.adk8978},
  abstract = {Quantum many-body scars are notable as nonthermal, low-entanglement states that exist at high energies. In this study, we used attractively interacting dysprosium gases to create scar states that are stable enough to be driven into a strongly nonlinear regime while retaining their character. We measured how the kinetic and total energies evolve after quenching the confining potential. Although the bare interactions are attractive, the atoms behave as if they repel each other: Their kinetic energy paradoxically decreases as the gas is compressed. The missing “phantom” energy is quantified by benchmarking our experimental results against generalized hydrodynamics calculations. We present evidence that the missing kinetic energy is carried by undetected, very high momentum atoms. Excited states of a many-body system are typically short-lived, but some systems have high-energy excitations known as quantum many-body scars that are much more resilient to thermalization. However, probing the scars is tricky. Yang et al. used a one-dimensional gas of dysprosium atoms to create quantum scars that are sufficiently stable for their nonlinear response to be probed. The researchers found that compressing the gas abruptly caused its kinetic energy to seemingly—and unexpectedly—decrease. A comparison with calculations revealed that the missing “phantom” energy, accounting for the difference between expectations and observations, is carried by high-momentum states that escape experimental detection. —Jelena Stajic},
}

